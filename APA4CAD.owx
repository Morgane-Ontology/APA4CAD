    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActeChirurgical</IRI>
        <Literal xml:lang="fr">Acte médical invasif réalisé par un chirurgien impliquant une intervention physique sur les tissus ou les organes afin de traiter, réparer ou remplacer une structure anatomique.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActeChirurgical</IRI>
        <Literal xml:lang="en">An invasive medical procedure performed by a surgeon involving physical intervention on tissues or organs to treat, repair, or replace an anatomical structure.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActeChirurgical</IRI>
        <Literal xml:lang="fr">Acte chirurgical</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActeChirurgical</IRI>
        <Literal xml:lang="en">Surgical Procedure</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#exactMatch"/>
        <IRI>#ActeChirurgical</IRI>
        <IRI>http://purl.bioontology.org/ontology/SNOMEDCT/387713003</IRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActeInterventionnel</IRI>
        <Literal xml:lang="en">A minimally invasive medical procedure, often image-guided, performed to diagnose or treat a condition without major open surgery.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActeInterventionnel</IRI>
        <Literal xml:lang="fr">Acte médical réalisé à l’aide de techniques mini-invasives, souvent guidées par imagerie, visant à diagnostiquer ou traiter une pathologie sans recours à une chirurgie ouverte majeure..</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActeInterventionnel</IRI>
        <Literal xml:lang="fr">Acte Interventionnel</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActeInterventionnel</IRI>
        <Literal xml:lang="en">Interventional  procedure</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActeMedical</IRI>
        <Literal xml:lang="en">A medical intervention performed by a healthcare professional for prevention, diagnosis, treatment, or monitoring of a patient.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActeMedical</IRI>
        <Literal xml:lang="fr">Intervention réalisée par un professionnel de santé dans un objectif de prévention, de diagnostic, de traitement ou de suivi d’un patient.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActeMedical</IRI>
        <Literal xml:lang="fr">Acte médical</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActeMedical</IRI>
        <Literal xml:lang="en">Medical act</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActiviteEndurance</IRI>
        <Literal xml:lang="en">A physical activity performed continuously or for a prolonged duration that primarily challenges the cardiovascular and respiratory systems to improve aerobic capacity.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActiviteEndurance</IRI>
        <Literal xml:lang="fr">Activité physique réalisée de manière continue ou prolongée sollicitant principalement le système cardiovasculaire et respiratoire afin d’améliorer la capacité aérobie.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActiviteEndurance</IRI>
        <Literal xml:lang="fr">Activité d&apos;endurance</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActiviteEndurance</IRI>
        <Literal xml:lang="en">Endurance activity</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActiviteMixte</IRI>
        <Literal xml:lang="en">A physical activity combining multiple components such as endurance, strength, balance, or coordination within the same practice.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActiviteMixte</IRI>
        <Literal xml:lang="fr">Activité physique combinant plusieurs composantes, telles que l’endurance, la force, l’équilibre ou la coordination, au sein d’une même pratique.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActiviteMixte</IRI>
        <Literal xml:lang="fr">Activité mixte</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActiviteMixte</IRI>
        <Literal xml:lang="en">Mixed activity</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActivitePhysique</IRI>
        <Literal xml:lang="en">Any bodily movement produced by skeletal muscles that results in energy expenditure above resting level.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ActivitePhysique</IRI>
        <Literal xml:lang="fr">Tout mouvement corporel produit par les muscles squelettiques entraînant une dépense énergétique supérieure au repos.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActivitePhysique</IRI>
        <Literal xml:lang="fr">Activité physique</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ActivitePhysique</IRI>
        <Literal xml:lang="en">Physical Activity</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#exactMatch"/>
        <IRI>#ActivitePhysique</IRI>
        <IRI>http://purl.bioontology.org/ontology/SNOMEDCT/390736008</IRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Adaptation</IRI>
        <Literal xml:lang="fr">Modification d’une activité, d’un exercice ou d’une intervention afin de l’ajuster aux capacités, besoins ou limitations d’une personne.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
