        <IRI>#CoronaropathieAsymptomatique</IRI>
        <Literal xml:lang="en">Coronary artery disease present without apparent clinical symptoms, often detected during screening or cardiovascular investigations.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CoronaropathieAsymptomatique</IRI>
        <Literal xml:lang="fr">Présence d’une maladie coronarienne objectivée sans symptômes cliniques apparents, pouvant être détectée lors d’examens de dépistage ou d’explorations cardiovasculaires.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CoronaropathieAsymptomatique</IRI>
        <Literal xml:lang="en">Asymptomatic coronary artery disease</Literal>
