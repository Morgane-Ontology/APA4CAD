        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AngorStable</IRI>
        <Literal xml:lang="en">A chronic clinical manifestation of coronary artery disease characterized by predictable chest pain occurring during exertion and relieved by rest or medication.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AngorStable</IRI>
        <Literal xml:lang="fr">Manifestation clinique chronique de la maladie coronarienne caractérisée par des douleurs thoraciques prévisibles survenant généralement à l’effort et disparaissant au repos ou après traitement.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
