    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AmeliorationCapaciteCardiorespiratoire</IRI>
        <Literal xml:lang="en">An objective aimed at improving the efficiency of the cardiovascular and respiratory systems during effort in order to increase endurance and exercise tolerance.</Literal>
    </AnnotationAssertion>
