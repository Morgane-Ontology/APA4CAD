        <IRI>#AmeliorationAmplitudeArticulaire</IRI>
        <Literal xml:lang="en">An objective aimed at increasing or maintaining joint range of motion and flexibility of musculoskeletal structures to facilitate functional movement.</Literal>
    </AnnotationAssertion>
