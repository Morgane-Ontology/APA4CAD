        <IRI>#AngioplastieAvecStent</IRI>
        <Literal xml:lang="en">A minimally invasive interventional procedure involving dilation of a narrowed coronary artery using a balloon followed by stent implantation to maintain vessel patency and improve blood flow.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AngioplastieAvecStent</IRI>
        <Literal xml:lang="fr">Acte interventionnel mini-invasif consistant à dilater une artère coronaire rétrécie à l’aide d’un ballonnet, puis à implanter un stent afin de maintenir l’ouverture du vaisseau et améliorer le flux sanguin.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
