        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AngorInstable</IRI>
        <Literal xml:lang="en">An acute form of coronary syndrome characterized by new-onset, worsening, or rest-related chest pain caused by transient reduction of coronary blood flow without myocardial necrosis.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AngorInstable</IRI>
        <Literal xml:lang="fr">Forme aiguë de syndrome coronarien caractérisée par des douleurs thoraciques d’apparition récente, d’aggravation progressive ou survenant au repos, liées à une diminution transitoire du flux sanguin coronaire sans nécrose myocardique.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
