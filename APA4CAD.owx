        <IRI>#CoronaropathieChronique</IRI>
        <Literal xml:lang="en">A stable and progressive form of coronary artery disease characterized by persistent reduction of myocardial blood flow, potentially leading to exertional ischemic symptoms.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CoronaropathieChronique</IRI>
        <Literal xml:lang="fr">Forme stable et évolutive de la maladie coronarienne caractérisée par une réduction durable du flux sanguin myocardique, pouvant entraîner des symptômes d’ischémie à l’effort.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CoronaropathieChronique</IRI>
        <Literal xml:lang="en">Chronic coronary syndrome</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CoronaropathieChronique</IRI>
        <Literal xml:lang="fr">Coronaropathie chronique</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CoronaropathieFonctionnelle</IRI>
        <Literal xml:lang="en">A coronary disorder without major anatomical obstruction, related to functional abnormalities of coronary circulation that may cause myocardial ischemia.</Literal>
