        <rdfs:label xml:lang="fr">Swiss ball</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SyndromeCoronarienAigu">
        <rdfs:label xml:lang="en">Acute coronary syndrome</rdfs:label>
        <rdfs:label xml:lang="fr">Syndrome coronarien aigu</rdfs:label>
        <skos:definition xml:lang="en">An acute manifestation of coronary artery disease resulting from sudden reduction of coronary blood flow, including clinical conditions such as myocardial infarction or unstable angina.</skos:definition>
        <skos:definition xml:lang="fr">Manifestation aiguë de la maladie coronarienne résultant d’une réduction soudaine du flux sanguin coronaire, incluant des situations cliniques telles que l’infarctus du myocarde ou l’angor instable.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/394659003"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#TapisDeMarche">
        <rdfs:label xml:lang="fr">Tapis de marche</rdfs:label>
        <rdfs:label xml:lang="en">Treadmill</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#TapisDeSol">
        <rdfs:label xml:lang="en">Floor mat</rdfs:label>
        <rdfs:label xml:lang="fr">Tapis de sol</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Tennis">
        <skos:definition xml:lang="en">Racket sport opposing two players or teams involving striking a ball over a net within a defined court.</skos:definition>
        <skos:definition xml:lang="fr">Sport de raquette opposant deux joueurs ou deux équipes consistant à frapper une balle au-dessus d’un filet sur un terrain délimité.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#TirageHorizontal">
        <rdfs:label xml:lang="en">Horizontal rowing exercice</rdfs:label>
        <rdfs:label xml:lang="fr">Tirage horizontal</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#TirageVertical">
        <rdfs:label xml:lang="fr">Tirage vertical</rdfs:label>
        <rdfs:label xml:lang="en">Vertical row</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Traction">
        <rdfs:label xml:lang="en">Pull-up</rdfs:label>
        <rdfs:label xml:lang="fr">Traction</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#TravailEnIsometrie">
        <rdfs:label xml:lang="en">Isometric exercise</rdfs:label>
        <rdfs:label xml:lang="fr">Travail en isométrie</rdfs:label>
        <skos:definition xml:lang="fr">Exercice impliquant une contraction musculaire statique sans mouvement articulaire visible.</skos:definition>
        <skos:definition xml:lang="en">Exercise involving static muscle contraction without visible joint movement.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#TroubleRespiratoire">
        <rdfs:label xml:lang="en">Respiratory disorder</rdfs:label>
        <rdfs:label xml:lang="fr">Trouble respiratoire</rdfs:label>
        <skos:definition xml:lang="en">Acute or chronic impairment of respiratory function that may limit exercise tolerance.</skos:definition>
        <skos:definition xml:lang="fr">Altération aiguë ou chronique de la fonction respiratoire susceptible de limiter la tolérance à l’effort.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#UtilisationEquipementPublic">
        <rdfs:label xml:lang="en">Use of public equipment</rdfs:label>
        <rdfs:label xml:lang="fr">Utilisation d&apos;équipement public</rdfs:label>
        <skos:definition xml:lang="fr">Recours à des infrastructures ou équipements publics accessibles (parcours de santé, installations urbaines).</skos:definition>
        <skos:definition xml:lang="en">Use of accessible public infrastructures or equipment (fitness trails, urban installations).</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#UtilisationVoieVerte">
        <rdfs:label>Use of greenway path</rdfs:label>
        <rdfs:label xml:lang="fr">Utilisation de voie verte</rdfs:label>
        <skos:definition xml:lang="en">Practice on dedicated safe paths promoting security and regularity of physical activity.</skos:definition>
        <skos:definition xml:lang="fr">Pratique sur des itinéraires sécurisés dédiés aux mobilités douces favorisant la sécurité et la régularité.fr</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Velo">
        <rdfs:label xml:lang="en">Bike</rdfs:label>
        <rdfs:label xml:lang="fr">Vélo</rdfs:label>
        <skos:definition xml:lang="fr">Activité physique consistant en un déplacement propulsé par pédalage sur un cycle, sollicitant principalement les membres inférieurs et le système cardiovasculaire.</skos:definition>
        <skos:definition xml:lang="en">Physical activity involving locomotion through pedaling on a bicycle, primarily engaging the lower limbs and the cardiovascular system.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#VeloBras">
        <rdfs:label xml:lang="fr">Vélo à bras</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#VeloDeRoute">
