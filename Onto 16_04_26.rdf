    <!-- http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AbsenceEspaceVert -->

    <owl:Class rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AbsenceEspaceVert">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AbsenceInfrastructure"/>
        <rdfs:label xml:lang="fr">Absence d&apos;espaces verts</rdfs:label>
        <rdfs:label xml:lang="en">Lack of green space</rdfs:label>
        <skos:definition xml:lang="fr">Situation caractérisée par l’absence ou l’accès limité à des espaces extérieurs naturels ou aménagés favorables à la pratique d’une activité physique.</skos:definition>
        <skos:definition xml:lang="en">Situation characterized by the absence or limited access to natural or landscaped outdoor areas suitable for physical activity practice.</skos:definition>
    </owl:Class>
    


