    <rdf:Description rdf:about="http://purl.org/dc/terms/Agent">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A resource that acts or has the power to act.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Agent</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/AgentClass">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A group of agents.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Agent Class</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/BibliographicResource">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A book, article, or other documentary resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Bibliographic Resource</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/Box">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">The set of regions in space defined by their geographic coordinates according to the DCMI Box Encoding Scheme.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">DCMI Box</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-box/"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/FileFormat">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A digital resource format.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">File Format</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/Frequency">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A rate at which something recurs.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Frequency</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/ISO3166">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">The set of codes listed in ISO 3166-1 for the representation of names of countries.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">ISO 3166</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://www.iso.org/obp/ui/#search"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/ISO639-2">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">The three-letter alphabetic codes listed in ISO639-2 for the representation of names of languages.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">ISO 639-2</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://lcweb.loc.gov/standards/iso639-2/langhome.html"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/ISO639-3">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">The set of three-letter codes listed in ISO 639-3 for the representation of names of languages.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">ISO 639-3</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.sil.org/iso639-3/"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/Jurisdiction">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">The extent or range of judicial, law enforcement, or other authority.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Jurisdiction</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/LicenseDocument">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A legal document giving official permission to do something with a resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">License Document</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/LinguisticSystem">
        <terms:description xml:lang="en">Written, spoken, sign, and computer languages are linguistic systems.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A system of signs, symbols, sounds, gestures, or rules used in communication.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Linguistic System</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/Location">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A spatial region or named place.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Location</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/LocationPeriodOrJurisdiction">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A location, period of time, or jurisdiction.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Location, Period, or Jurisdiction</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/MediaType">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A file format or physical medium.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Media Type</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/MediaTypeOrExtent">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A media type or extent.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Media Type or Extent</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/MethodOfAccrual">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A method by which resources are added to a collection.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Method of Accrual</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/MethodOfInstruction">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A process that is used to engender knowledge, attitudes, and skills.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Method of Instruction</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/Period">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">The set of time intervals defined by their limits according to the DCMI Period Encoding Scheme.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">DCMI Period</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-period/"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/PeriodOfTime">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">An interval of time that is named or defined by its start and end dates.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Period of Time</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/PhysicalMedium">
        <terms:description xml:lang="en">Examples include paper, canvas, or DVD.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A physical material or carrier.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Physical Medium</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/PhysicalResource">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A material thing.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Physical Resource</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/Point">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">The set of points in space defined by their geographic coordinates according to the DCMI Point Encoding Scheme.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">DCMI Point</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-point/"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/Policy">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A plan or course of action by an authority, intended to influence and determine decisions, actions, and other matters.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Policy</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/ProvenanceStatement">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">Any changes in ownership and custody of a resource since its creation that are significant for its authenticity, integrity, and interpretation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Provenance Statement</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/RFC1766">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">The set of tags, constructed according to RFC 1766, for the identification of languages.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">RFC 1766</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.ietf.org/rfc/rfc1766.txt"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/RFC3066">
        <terms:description xml:lang="en">RFC 3066 has been obsoleted by RFC 4646.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-07-13</terms:issued>
        <rdfs:comment xml:lang="en">The set of tags constructed according to RFC 3066 for the identification of languages.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">RFC 3066</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.ietf.org/rfc/rfc3066.txt"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/RFC4646">
        <terms:description xml:lang="en">RFC 4646 obsoletes RFC 3066.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">The set of tags constructed according to RFC 4646 for the identification of languages.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">RFC 4646</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.ietf.org/rfc/rfc4646.txt"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/RFC5646">
        <terms:description xml:lang="en">RFC 5646 obsoletes RFC 4646.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2010-10-11</terms:issued>
        <rdfs:comment xml:lang="en">The set of tags constructed according to RFC 5646 for the identification of languages.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">RFC 5646</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.ietf.org/rfc/rfc5646.txt"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/RightsStatement">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A statement about the intellectual property rights (IPR) held in or over a resource, a legal document giving official permission to do something with a resource, or a statement about access rights.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Rights Statement</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/SizeOrDuration">
        <terms:description xml:lang="en">Examples include a number of pages, a specification of length, width, and breadth, or a period in hours, minutes, and seconds.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A dimension or extent, or a time taken to play or execute.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Size or Duration</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/Standard">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A reference point against which other things can be evaluated or compared.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Standard</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/URI">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">The set of identifiers constructed according to the generic syntax for Uniform Resource Identifiers as specified by the Internet Engineering Task Force.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">URI</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.ietf.org/rfc/rfc3986.txt"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/W3CDTF">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">The set of dates and times constructed according to the W3C Date and Time Formats Specification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">W3C-DTF</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/TR/NOTE-datetime"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/abstract">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A summary of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Abstract</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/accessRights">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/RightsStatement"/>
        <terms:description xml:lang="en">Access Rights may include information regarding access or restrictions based on privacy, security, or other policies.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2003-02-15</terms:issued>
        <rdfs:comment xml:lang="en">Information about who access the resource or an indication of its security status.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Access Rights</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/accrualMethod">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/MethodOfAccrual"/>
        <terms:description xml:lang="en">Recommended practice is to use a value from the Collection Description Accrual Method Vocabulary [[DCMI-ACCRUALMETHOD](https://dublincore.org/groups/collections/accrual-method/)].</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2005-06-13</terms:issued>
        <rdfs:comment xml:lang="en">The method by which items are added to a collection.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Accrual Method</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/accrualPeriodicity">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/Frequency"/>
        <terms:description xml:lang="en">Recommended practice is to use a value from the Collection Description Frequency Vocabulary [[DCMI-COLLFREQ](https://dublincore.org/groups/collections/frequency/)].</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2005-06-13</terms:issued>
        <rdfs:comment xml:lang="en">The frequency with which items are added to a collection.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Accrual Periodicity</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/accrualPolicy">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/Policy"/>
        <terms:description xml:lang="en">Recommended practice is to use a value from the Collection Description Accrual Policy Vocabulary [[DCMI-ACCRUALPOLICY](https://dublincore.org/groups/collections/accrual-policy/)].</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2005-06-13</terms:issued>
        <rdfs:comment xml:lang="en">The policy governing the addition of items to a collection.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Accrual Policy</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/alternative">
        <terms:description xml:lang="en">The distinction between titles and alternative titles is application-specific.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">An alternative name for the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Alternative Title</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/audience">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/AgentClass"/>
        <terms:description xml:lang="en">Recommended practice is to use this property with non-literal values from a vocabulary of audience types.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-05-21</terms:issued>
        <rdfs:comment xml:lang="en">A class of agents for whom the resource is intended or useful.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Audience</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/available">
        <terms:description xml:lang="en">Recommended practice is to describe the date, date/time, or period of time as recommended for the property Date, of which this is a subproperty.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">Date that the resource became or will become available.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Date Available</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/bibliographicCitation">
        <terms:description xml:lang="en">Recommended practice is to include sufficient bibliographic detail to identify the resource as unambiguously as possible.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2003-02-15</terms:issued>
        <rdfs:comment xml:lang="en">A bibliographic reference for the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Bibliographic Citation</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/conformsTo">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/Standard"/>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-05-21</terms:issued>
        <rdfs:comment xml:lang="en">An established standard to which the described resource conforms.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Conforms To</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/contributor">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/Agent"/>
        <terms:description xml:lang="en">The guidelines for using names of persons or organizations as creators apply to contributors.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">An entity responsible for making contributions to the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Contributor</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/coverage">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/Jurisdiction"/>
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/Location"/>
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/Period"/>
        <terms:description xml:lang="en">Spatial topic and spatial applicability may be a named place or a location specified by its geographic coordinates. Temporal topic may be a named period, date, or date range. A jurisdiction may be a named administrative entity or a geographic place to which the resource applies. Recommended practice is to use a controlled vocabulary such as the Getty Thesaurus of Geographic Names [[TGN](https://www.getty.edu/research/tools/vocabulary/tgn/index.html)]. Where appropriate, named places or time periods may be used in preference to numeric identifiers such as sets of coordinates or date ranges.  Because coverage is so broadly defined, it is preferable to use the more specific subproperties Temporal Coverage and Spatial Coverage.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">The spatial or temporal topic of the resource, spatial applicability of the resource, or jurisdiction under which the resource is relevant.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Coverage</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/created">
        <terms:description xml:lang="en">Recommended practice is to describe the date, date/time, or period of time as recommended for the property Date, of which this is a subproperty.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">Date of creation of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Date Created</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/creator">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/Agent"/>
        <terms:description xml:lang="en">Recommended practice is to identify the creator with a URI.  If this is not possible or feasible, a literal value that identifies the creator may be provided.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">An entity responsible for making the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Creator</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/date">
        <terms:description xml:lang="en">Date may be used to express temporal information at any level of granularity.  Recommended practice is to express the date, date/time, or period of time according to ISO 8601-1 [[ISO 8601-1](https://www.iso.org/iso-8601-date-and-time-format.html)] or a published profile of the ISO standard, such as the W3C Note on Date and Time Formats [[W3CDTF](https://www.w3.org/TR/NOTE-datetime)] or the Extended Date/Time Format Specification [[EDTF](http://www.loc.gov/standards/datetime/)].  If the full date is unknown, month and year (YYYY-MM) or just year (YYYY) may be used. Date ranges may be specified using ISO 8601 period of time specification in which start and end dates are separated by a &apos;/&apos; (slash) character.  Either the start or end date may be missing.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A point or period of time associated with an event in the lifecycle of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Date</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/dateAccepted">
        <terms:description xml:lang="en">Recommended practice is to describe the date, date/time, or period of time as recommended for the property Date, of which this is a subproperty.  Examples of resources to which a date of acceptance may be relevant are a thesis (accepted by a university department) or an article (accepted by a journal).</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-07-13</terms:issued>
        <rdfs:comment xml:lang="en">Date of acceptance of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Date Accepted</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/dateCopyrighted">
        <terms:description xml:lang="en">Typically a year.  Recommended practice is to describe the date, date/time, or period of time as recommended for the property Date, of which this is a subproperty.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-07-13</terms:issued>
        <rdfs:comment xml:lang="en">Date of copyright of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Date Copyrighted</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/dateSubmitted">
        <terms:description xml:lang="en">Recommended practice is to describe the date, date/time, or period of time as recommended for the property Date, of which this is a subproperty.  Examples of resources to which a &apos;Date Submitted&apos; may be relevant include a thesis (submitted to a university department) or an article (submitted to a journal).</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-07-13</terms:issued>
        <rdfs:comment xml:lang="en">Date of submission of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Date Submitted</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/description">
        <terms:description xml:lang="en">Description may include but is not limited to: an abstract, a table of contents, a graphical representation, or a free-text account of the resource.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">An account of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Description</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/educationLevel">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/AgentClass"/>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2002-07-13</terms:issued>
        <rdfs:comment xml:lang="en">A class of agents, defined in terms of progression through an educational or training context, for which the described resource is intended.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Audience Education Level</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/extent">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/SizeOrDuration"/>
        <terms:description xml:lang="en">Recommended practice is to specify the file size in megabytes and duration in ISO 8601 format.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">The size or duration of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Extent</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/format">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/Extent"/>
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/MediaType"/>
        <terms:description xml:lang="en">Recommended practice is to use a controlled vocabulary where available. For example, for file formats one could use the list of Internet Media Types [[MIME](https://www.iana.org/assignments/media-types/media-types.xhtml)].  Examples of dimensions include size and duration.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">The file format, physical medium, or dimensions of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Format</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/hasFormat">
        <terms:description xml:lang="en">This property is intended to be used with non-literal values. This property is an inverse property of Is Format Of.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A related resource that is substantially the same as the pre-existing described resource, but in another format.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Has Format</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/hasPart">
        <terms:description xml:lang="en">This property is intended to be used with non-literal values. This property is an inverse property of Is Part Of.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A related resource that is included either physically or logically in the described resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Has Part</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/hasVersion">
        <terms:description xml:lang="en">Changes in version imply substantive changes in content rather than differences in format. This property is intended to be used with non-literal values. This property is an inverse property of Is Version Of.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A related resource that is a version, edition, or adaptation of the described resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Has Version</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/identifier">
        <terms:description xml:lang="en">Recommended practice is to identify the resource by means of a string conforming to an identification system. Examples include International Standard Book Number (ISBN), Digital Object Identifier (DOI), and Uniform Resource Name (URN).  Persistent identifiers should be provided as HTTP URIs.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">An unambiguous reference to the resource within a given context.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Identifier</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/isFormatOf">
        <terms:description xml:lang="en">This property is intended to be used with non-literal values. This property is an inverse property of Has Format.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A pre-existing related resource that is substantially the same as the described resource, but in another format.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Is Format Of</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/isPartOf">
        <terms:description xml:lang="en">This property is intended to be used with non-literal values. This property is an inverse property of Has Part.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A related resource in which the described resource is physically or logically included.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Is Part Of</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/isReferencedBy">
        <terms:description xml:lang="en">This property is intended to be used with non-literal values. This property is an inverse property of References.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A related resource that references, cites, or otherwise points to the described resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Is Referenced By</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/isReplacedBy">
        <terms:description xml:lang="en">This property is intended to be used with non-literal values. This property is an inverse property of Replaces.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A related resource that supplants, displaces, or supersedes the described resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Is Replaced By</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/isRequiredBy">
        <terms:description xml:lang="en">This property is intended to be used with non-literal values. This property is an inverse property of Requires.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A related resource that requires the described resource to support its function, delivery, or coherence.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Is Required By</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/isVersionOf">
        <terms:description xml:lang="en">Changes in version imply substantive changes in content rather than differences in format. This property is intended to be used with non-literal values. This property is an inverse property of Has Version.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A related resource of which the described resource is a version, edition, or adaptation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Is Version Of</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/issued">
        <terms:description xml:lang="en">Recommended practice is to describe the date, date/time, or period of time as recommended for the property Date, of which this is a subproperty.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">Date of formal issuance of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Date Issued</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/language">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/LinguisticSystem"/>
        <terms:description xml:lang="en">Recommended practice is to use either a non-literal value representing a language from a controlled vocabulary such as ISO 639-2 or ISO 639-3, or a literal value consisting of an IETF Best Current Practice 47 [[IETF-BCP47](https://tools.ietf.org/html/bcp47)] language tag.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A language of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Language</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/license">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/LicenseDocument"/>
        <terms:description xml:lang="en">Recommended practice is to identify the license document with a URI. If this is not possible or feasible, a literal value that identifies the license may be provided.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2004-06-14</terms:issued>
        <rdfs:comment xml:lang="en">A legal document giving official permission to do something with the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">License</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/mediator">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/AgentClass"/>
        <terms:description xml:lang="en">In an educational context, a mediator might be a parent, teacher, teaching assistant, or care-giver.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-05-21</terms:issued>
        <rdfs:comment xml:lang="en">An entity that mediates access to the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Mediator</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/medium">
        <dcam:domainIncludes rdf:resource="http://purl.org/dc/terms/PhysicalResource"/>
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/PhysicalMedium"/>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">The material or physical carrier of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Medium</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/modified">
        <terms:description xml:lang="en">Recommended practice is to describe the date, date/time, or period of time as recommended for the property Date, of which this is a subproperty.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">Date on which the resource was changed.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Date Modified</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/publisher">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/Agent"/>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">An entity responsible for making the resource available.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Publisher</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/references">
        <terms:description xml:lang="en">This property is intended to be used with non-literal values. This property is an inverse property of Is Referenced By.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A related resource that is referenced, cited, or otherwise pointed to by the described resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">References</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/relation">
        <terms:description xml:lang="en">Recommended practice is to identify the related resource by means of a URI.  If this is not possible or feasible, a string conforming to a formal identification system may be provided.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A related resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Relation</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/replaces">
        <terms:description xml:lang="en">This property is intended to be used with non-literal values. This property is an inverse property of Is Replaced By.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A related resource that is supplanted, displaced, or superseded by the described resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Replaces</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/requires">
        <terms:description xml:lang="en">This property is intended to be used with non-literal values. This property is an inverse property of Is Required By.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A related resource that is required by the described resource to support its function, delivery, or coherence.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Requires</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/rights">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/RightsStatement"/>
        <terms:description xml:lang="en">Typically, rights information includes a statement about various property rights associated with the resource, including intellectual property rights.  Recommended practice is to refer to a rights statement with a URI.  If this is not possible or feasible, a literal value (name, label, or short text) may be provided.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">Information about rights held in and over the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Rights</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/source">
        <terms:description xml:lang="en">This property is intended to be used with non-literal values. The described resource may be derived from the related resource in whole or in part. Best practice is to identify the related resource by means of a URI or a string conforming to a formal identification system.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A related resource from which the described resource is derived.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Source</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/spatial">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/Location"/>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">Spatial characteristics of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Spatial Coverage</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/subject">
        <terms:description xml:lang="en">Recommended practice is to refer to the subject with a URI. If this is not possible or feasible, a literal value that identifies the subject may be provided. Both should preferably refer to a subject in a controlled vocabulary.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A topic of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Subject</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/tableOfContents">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">A list of subunits of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Table Of Contents</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/temporal">
        <dcam:rangeIncludes rdf:resource="http://purl.org/dc/terms/PeriodOfTime"/>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">Temporal characteristics of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Temporal Coverage</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/title">
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">A name given to the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Title</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/type">
        <terms:description xml:lang="en">Recommended practice is to use a controlled vocabulary such as the DCMI Type Vocabulary [[DCMI-TYPE](http://dublincore.org/documents/dcmi-type-vocabulary/)]. To describe the file format, physical medium, or dimensions of the resource, use the property Format.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2008-01-14</terms:issued>
        <rdfs:comment xml:lang="en">The nature or genre of the resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Type</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://purl.org/dc/terms/valid">
        <terms:description xml:lang="en">Recommended practice is to describe the date, date/time, or period of time as recommended for the property Date, of which this is a subproperty.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2000-07-11</terms:issued>
        <rdfs:comment xml:lang="en">Date (often a range) of validity of a resource.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">Date Valid</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AbdosSurChaise">
        <rdfs:label xml:lang="fr">Abdos sur chaise</rdfs:label>
        <rdfs:label xml:lang="en">Seated abdominal exercie</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AbductionDeJambe">
        <rdfs:label xml:lang="fr">Abduction de jambe</rdfs:label>
        <rdfs:label xml:lang="en">Leg abduction</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AbsenceGymnase">
        <rdfs:label xml:lang="fr">Absence de gymnase</rdfs:label>
        <rdfs:label xml:lang="en">Lack of gymnasium</rdfs:label>
        <skos:definition xml:lang="fr">Indisponibilité d’un espace couvert équipé permettant la pratique d’activités physiques ou sportives en intérieur.</skos:definition>
        <skos:definition xml:lang="en">Unavailability of an equipped indoor facility allowing the practice of physical or sporting activities.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AbsenceInfrastructure">
        <rdfs:label xml:lang="fr">Absence d&apos;infrastructure</rdfs:label>
        <rdfs:label xml:lang="en">Lack of infrastructure</rdfs:label>
        <skos:definition xml:lang="fr">Situation caractérisée par l’indisponibilité ou l’insuffisance d’équipements, d’installations ou d’aménagements permettant la pratique d’une activité physique.</skos:definition>
        <skos:definition xml:lang="en">Situation characterized by the unavailability or insufficiency of facilities, equipment, or built environments enabling physical activity practice.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ActeChirurgical">
        <rdfs:label xml:lang="fr">Acte chirurgical</rdfs:label>
        <rdfs:label xml:lang="en">Surgical Procedure</rdfs:label>
        <skos:definition xml:lang="fr">Acte médical invasif réalisé par un chirurgien impliquant une intervention physique sur les tissus ou les organes afin de traiter, réparer ou remplacer une structure anatomique.</skos:definition>
        <skos:definition xml:lang="en">An invasive medical procedure performed by a surgeon involving physical intervention on tissues or organs to treat, repair, or replace an anatomical structure.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/387713003"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ActeInterventionnel">
        <rdfs:label xml:lang="fr">Acte Interventionnel</rdfs:label>
        <rdfs:label xml:lang="en">Interventional  procedure</rdfs:label>
        <skos:definition xml:lang="en">A minimally invasive medical procedure, often image-guided, performed to diagnose or treat a condition without major open surgery.</skos:definition>
        <skos:definition xml:lang="fr">Acte médical réalisé à l’aide de techniques mini-invasives, souvent guidées par imagerie, visant à diagnostiquer ou traiter une pathologie sans recours à une chirurgie ouverte majeure..</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ActeMedical">
        <rdfs:label xml:lang="fr">Acte médical</rdfs:label>
        <rdfs:label xml:lang="en">Medical act</rdfs:label>
        <skos:definition xml:lang="en">A medical intervention performed by a healthcare professional for prevention, diagnosis, treatment, or monitoring of a patient.</skos:definition>
        <skos:definition xml:lang="fr">Intervention réalisée par un professionnel de santé dans un objectif de prévention, de diagnostic, de traitement ou de suivi d’un patient.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/71388002"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ActiviteDomicile">
        <rdfs:label xml:lang="fr">Activité à domicile</rdfs:label>
        <rdfs:label xml:lang="en">Home-based activity</rdfs:label>
        <skos:definition>Physical activity performed at home to reduce logistical or environmental constraints.</skos:definition>
        <skos:definition xml:lang="fr">Pratique réalisée au domicile afin de réduire les contraintes logistiques ou environnementales.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ActiviteEnInterieur">
        <rdfs:label xml:lang="fr">Activité en interieur</rdfs:label>
        <rdfs:label xml:lang="en">Indoor activity</rdfs:label>
        <skos:definition xml:lang="en">Activity performed indoors to minimize climatic influence.</skos:definition>
        <skos:definition xml:lang="fr">Pratique effectuée dans un espace couvert afin de limiter l’impact des conditions climatiques.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ActiviteEndurance">
        <rdfs:label xml:lang="fr">Activité d&apos;endurance</rdfs:label>
        <rdfs:label xml:lang="en">Endurance activity</rdfs:label>
        <skos:definition xml:lang="en">A physical activity performed continuously or for a prolonged duration that primarily challenges the cardiovascular and respiratory systems to improve aerobic capacity.</skos:definition>
        <skos:definition xml:lang="fr">Activité physique réalisée de manière continue ou prolongée sollicitant principalement le système cardiovasculaire et respiratoire afin d’améliorer la capacité aérobie.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ActiviteMixte">
        <rdfs:label xml:lang="fr">Activité mixte</rdfs:label>
        <rdfs:label xml:lang="en">Mixed activity</rdfs:label>
        <skos:definition xml:lang="en">A physical activity combining multiple components such as endurance, strength, balance, or coordination within the same practice.</skos:definition>
        <skos:definition xml:lang="fr">Activité physique combinant plusieurs composantes, telles que l’endurance, la force, l’équilibre ou la coordination, au sein d’une même pratique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ActivitePhysique">
        <rdfs:label xml:lang="fr">Activité physique</rdfs:label>
        <rdfs:label xml:lang="en">Physical Activity</rdfs:label>
        <skos:closeMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/68130003"/>
        <skos:definition xml:lang="en">Any bodily movement produced by skeletal muscles that results in energy expenditure above resting level.</skos:definition>
        <skos:definition xml:lang="fr">Tout mouvement corporel produit par les muscles squelettiques entraînant une dépense énergétique supérieure au repos.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ActivitePlaisir">
        <rdfs:label xml:lang="fr">Activité plaisir</rdfs:label>
        <rdfs:label>Enjoyable activity</rdfs:label>
        <skos:definition xml:lang="en">Activity selected for its enjoyable nature to enhance intrinsic motivation.</skos:definition>
        <skos:definition>Activité choisie pour son caractère agréable afin de renforcer la motivation intrinsèque.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ActiviteSansMateriel">
        <rdfs:label xml:lang="fr">Activité sans matériel</rdfs:label>
        <rdfs:label xml:lang="en">Equipment-free activity</rdfs:label>
        <skos:definition xml:lang="en">Activity that can be performed without specific equipment to reduce material barriers.</skos:definition>
        <skos:definition xml:lang="fr">Activité réalisable sans matériel spécifique afin de réduire les barrières matérielles.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Adaptation">
        <rdfs:label xml:lang="en">Adaptation</rdfs:label>
        <rdfs:label xml:lang="fr">Adaptation</rdfs:label>
        <skos:closeMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/228649000"/>
        <skos:definition xml:lang="fr">Modification d’une activité, d’un exercice ou d’une intervention afin de l’ajuster aux capacités, besoins ou limitations d’une personne.</skos:definition>
        <skos:definition xml:lang="en">Modification of an activity, exercise, or intervention to fit an individual’s capacities, needs, or limitations.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AdductionDeJambe">
        <rdfs:label xml:lang="fr">Adduction de jambe</rdfs:label>
        <rdfs:label xml:lang="en">Leg adduction</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AffectionDeLongueDuree">
        <rdfs:label xml:lang="fr">Affection de longue durée</rdfs:label>
        <rdfs:label xml:lang="en">Chronic condition</rdfs:label>
        <skos:definition xml:lang="en">A chronic medical condition requiring long-term management and potentially leading to functional limitations or ongoing therapeutic follow-up.</skos:definition>
        <skos:definition xml:lang="fr">Condition médicale chronique nécessitant une prise en charge prolongée et pouvant entraîner des limitations fonctionnelles ou un suivi thérapeutique durable.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Alpinisme">
        <rdfs:label xml:lang="fr">Alpinisme</rdfs:label>
        <rdfs:label xml:lang="en">Mountaineering</rdfs:label>
        <skos:definition xml:lang="en">Activité sportive de progression en terrain montagneux pouvant inclure escalade, neige, glace et haute altitude.</skos:definition>
        <skos:definition xml:lang="fr">Activité sportive de progression en terrain montagneux pouvant inclure escalade, neige, glace et haute altitude.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AmeliorationAmplitudeArticulaire">
        <rdfs:label xml:lang="fr">Amélioration de l’amplitude</rdfs:label>
        <rdfs:label xml:lang="en">Improvement of range of motion</rdfs:label>
        <skos:definition xml:lang="en">An objective aimed at increasing or maintaining joint range of motion and flexibility of musculoskeletal structures to facilitate functional movement.</skos:definition>
        <skos:definition xml:lang="fr">Objectif visant à augmenter ou maintenir l’amplitude articulaire et la souplesse des structures musculo-squelettiques afin de faciliter le mouvement fonctionnel.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AmeliorationCapaciteCardiorespiratoire">
        <rdfs:label xml:lang="fr">Amélioration de la capacité cardio-respiratoire</rdfs:label>
        <rdfs:label xml:lang="en">Improvement of cardiorespiratory capacity</rdfs:label>
        <skos:definition xml:lang="en">An objective aimed at improving the efficiency of the cardiovascular and respiratory systems during effort in order to increase endurance and exercise tolerance.</skos:definition>
        <skos:definition xml:lang="fr">Objectif visant à améliorer l’efficacité des systèmes cardiovasculaire et respiratoire lors de l’effort afin d’augmenter l’endurance et la tolérance à l’exercice.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AmeliorationCapaciteMusculaire">
        <rdfs:label xml:lang="fr">Amélioration de la capacité musculaire</rdfs:label>
        <rdfs:label xml:lang="en">Improvement of muscular capacity</rdfs:label>
        <skos:definition xml:lang="en">An objective aimed at increasing or maintaining muscular strength, endurance, and function to improve functional performance and autonomy.</skos:definition>
        <skos:definition xml:lang="fr">Objectif visant à augmenter ou maintenir la force, l’endurance et la fonction musculaire afin d’améliorer la performance fonctionnelle et l’autonomie.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AngioplastieAvecStent">
        <rdfs:label xml:lang="fr">Angioplastie avec stent</rdfs:label>
        <rdfs:label xml:lang="en">Percutaneous coronary intervention with stent</rdfs:label>
        <skos:definition xml:lang="en">A minimally invasive interventional procedure involving dilation of a narrowed coronary artery using a balloon followed by stent implantation to maintain vessel patency and improve blood flow.</skos:definition>
        <skos:definition xml:lang="fr">Acte interventionnel mini-invasif consistant à dilater une artère coronaire rétrécie à l’aide d’un ballonnet, puis à implanter un stent afin de maintenir l’ouverture du vaisseau et améliorer le flux sanguin.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/415070008"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AngorInstable">
        <rdfs:label xml:lang="fr">Angor instable</rdfs:label>
        <rdfs:label xml:lang="en">Unstable angina</rdfs:label>
        <skos:definition xml:lang="en">An acute form of coronary syndrome characterized by new-onset, worsening, or rest-related chest pain caused by transient reduction of coronary blood flow without myocardial necrosis.</skos:definition>
        <skos:definition xml:lang="fr">Forme aiguë de syndrome coronarien caractérisée par des douleurs thoraciques d’apparition récente, d’aggravation progressive ou survenant au repos, liées à une diminution transitoire du flux sanguin coronaire sans nécrose myocardique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AngorStable">
        <rdfs:label xml:lang="fr">Angor stable</rdfs:label>
        <rdfs:label xml:lang="en">Stable angina</rdfs:label>
        <skos:definition xml:lang="en">A chronic clinical manifestation of coronary artery disease characterized by predictable chest pain occurring during exertion and relieved by rest or medication.</skos:definition>
        <skos:definition xml:lang="fr">Manifestation clinique chronique de la maladie coronarienne caractérisée par des douleurs thoraciques prévisibles survenant généralement à l’effort et disparaissant au repos ou après traitement.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/233819005"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ApneeDuSommeil">
        <rdfs:label xml:lang="fr">Apnée du sommeil</rdfs:label>
        <rdfs:label xml:lang="en">Sleep apnea</rdfs:label>
        <skos:definition xml:lang="en">A sleep-related breathing disorder characterized by repeated interruptions or reductions of airflow caused by partial or complete obstruction of the upper airways during sleep, leading to micro-arousals and impaired sleep quality.</skos:definition>
        <skos:definition xml:lang="fr">Trouble respiratoire du sommeil caractérisé par des interruptions répétées ou une réduction de la respiration dues à une obstruction partielle ou complète des voies aériennes supérieures pendant le sommeil, entraînant des micro-réveils et une altération de la qualité du sommeil.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/73430006"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Aquagym">
        <rdfs:label xml:lang="en">Aquagym</rdfs:label>
        <rdfs:label xml:lang="fr">Gym aquatique</rdfs:label>
        <skos:definition xml:lang="fr">Activité physique réalisée en immersion partielle ou complète dans l’eau, combinant des exercices de renforcement musculaire et de mobilisation articulaire.</skos:definition>
        <skos:definition xml:lang="en">Physical activity performed in partial or full water immersion, combining muscular strengthening and joint mobilization exercises.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Arthrose">
        <rdfs:label xml:lang="fr">Arthrose</rdfs:label>
        <rdfs:label xml:lang="en">Osteoarthritis</rdfs:label>
        <skos:definition xml:lang="en">A chronic joint disease characterized by progressive degeneration of articular cartilage, potentially leading to pain, stiffness, and reduced mobility.</skos:definition>
        <skos:definition xml:lang="fr">Maladie articulaire chronique caractérisée par une usure progressive et une dégradation du cartilage articulaire, pouvant entraîner douleur, raideur et diminution de la mobilité.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/396275006"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ArthroseEpaule">
        <rdfs:label xml:lang="fr">Arthrose de l’épaule</rdfs:label>
        <rdfs:label xml:lang="en">Shoulder osteoarthritis</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ArthroseGenou">
        <rdfs:label xml:lang="fr">Arthrose du genou</rdfs:label>
        <rdfs:label xml:lang="en">Knee osteoarthritis</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ArthroseHanche">
        <rdfs:label xml:lang="fr">Arthrose de la hanche</rdfs:label>
        <rdfs:label xml:lang="en">Hip osteoarthritis</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Athletisme">
        <rdfs:label xml:lang="en">Athletics</rdfs:label>
        <rdfs:label xml:lang="fr">Athletisme</rdfs:label>
        <skos:definition xml:lang="en">Ensemble de disciplines sportives regroupant des épreuves de course, de saut, de lancer et d’épreuves combinées.</skos:definition>
        <skos:definition xml:lang="fr">Ensemble de disciplines sportives regroupant des épreuves de course, de saut, de lancer et d’épreuves combinées.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AutoMonitoring">
        <rdfs:label xml:lang="fr">Auto monitoring</rdfs:label>
        <rdfs:label>Self-monitoring</rdfs:label>
        <skos:definition xml:lang="fr">Independent tracking of performance or activity (logbook, wearable device) to enhance engagement.</skos:definition>
        <skos:definition xml:lang="fr">Suivi autonome des performances ou de l’activité (journal, montre connectée) afin de renforcer l’engagement.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#AvecChaise">
        <rdfs:label xml:lang="fr">Avec chaise</rdfs:label>
        <rdfs:label xml:lang="en">With chair</rdfs:label>
        <skos:definition xml:lang="en">Exercise performed with chair support to enhance stability and safety.</skos:definition>
        <skos:definition xml:lang="fr">Réalisation de l’exercice avec appui ou assistance d’une chaise afin d’améliorer la stabilité et la sécurité.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Badminton">
        <skos:definition xml:lang="en">Racket sport in which players use a racket to strike a shuttlecock over a net.</skos:definition>
        <skos:definition xml:lang="fr">Sport de raquette opposant des joueurs utilisant une raquette pour frapper un volant au-dessus d’un filet.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BallonPaille">
        <rdfs:label xml:lang="fr">Ballon paille</rdfs:label>
        <rdfs:label xml:lang="en">Straw balloon exercise</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BancDeMusculation">
        <rdfs:label xml:lang="fr">Banc de musculation</rdfs:label>
        <rdfs:label xml:lang="en">Weight bench</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BarreDeMusculation">
        <rdfs:label xml:lang="fr">Barre de musculation</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BarreDeTirageCoudee">
        <rdfs:label xml:lang="fr">Barre de tirage coudée</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BarreDeTirageDroite">
        <rdfs:label xml:lang="en">Barre de tirage droite</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BarreEnZ">
        <rdfs:label xml:lang="fr">Barre en Z</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Basketball">
        <skos:definition xml:lang="fr">Sport collectif opposant deux équipes dont l’objectif est de marquer des points en envoyant un ballon dans un panier surélevé.</skos:definition>
        <skos:definition xml:lang="en">Team sport opposing two teams aiming to score points by projecting a ball into an elevated hoop.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BeneficesActivite">
        <rdfs:label xml:lang="en">Awareness of activity benefits</rdfs:label>
        <rdfs:label xml:lang="fr">Bénéfices de l&apos;activité</rdfs:label>
        <skos:definition xml:lang="en">Highlighting physical and psychological benefits associated with regular practice.</skos:definition>
        <skos:definition xml:lang="fr">Mise en évidence des bénéfices physiques et psychologiques associés à la pratique régulière.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BinomeActivite">
        <rdfs:label xml:lang="en">Activity partener</rdfs:label>
        <rdfs:label xml:lang="fr">Binôme d&apos;activité</rdfs:label>
        <skos:definition xml:lang="en">Practicing with a partner to enhance accountability and adherence.</skos:definition>
        <skos:definition xml:lang="fr">Pratique en duo afin de renforcer l’engagement et la responsabilisation mutuelle.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Blessure">
        <rdfs:label xml:lang="fr">Blessure</rdfs:label>
        <rdfs:label xml:lang="en">Injury</rdfs:label>
        <skos:definition xml:lang="en">Acute or chronic damage to musculoskeletal tissue or an organ potentially limiting or preventing physical activity practice.</skos:definition>
        <skos:definition xml:lang="fr">Atteinte aiguë ou chronique d’un tissu musculosquelettique ou d’un organe susceptible de limiter ou d’empêcher la pratique d’une activité physique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BlessureArticulaire">
        <rdfs:label xml:lang="en">Articular injury</rdfs:label>
        <rdfs:label xml:lang="fr">Blessure articulaire</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BlessureLigamentaire">
        <rdfs:label xml:lang="fr">Blessure ligamentaire</rdfs:label>
        <rdfs:label xml:lang="en">Ligament injury</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BlessureMusculaire">
        <rdfs:label xml:lang="fr">Blessure musculaire</rdfs:label>
        <rdfs:label xml:lang="en">Muscle injury</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BlessureOsseuse">
        <rdfs:label xml:lang="fr">Blessure osseuse</rdfs:label>
        <rdfs:label xml:lang="en">Bone injury</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BlessureTendineuse">
        <rdfs:label xml:lang="fr">Blessure tendineuse</rdfs:label>
        <rdfs:label xml:lang="en">Tendon injury</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BorgFaible">
        <rdfs:label xml:lang="fr">Borg faible</rdfs:label>
        <rdfs:label xml:lang="en">Low borg</rdfs:label>
        <skos:definition xml:lang="en">A very light to light perceived level of exertion. The activity is performed without noticeable breathlessness and conversation remains easy and comfortable.</skos:definition>
        <skos:definition xml:lang="fr">Niveau d’effort perçu très léger à léger. L’activité est réalisée sans essoufflement notable et la conversation reste facile et fluide.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BorgIntense">
        <rdfs:label xml:lang="fr">Borg intense</rdfs:label>
        <rdfs:label xml:lang="en">High borg</rdfs:label>
        <skos:definition xml:lang="en">A very light to light perceived level of exertion. The activity is performed without noticeable breathlessness and conversation remains easy and comfortable.</skos:definition>
        <skos:definition xml:lang="fr">Niveau d’effort perçu intense provoquant une respiration marquée et une difficulté à parler pendant l’activité.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BorgModere">
        <rdfs:label xml:lang="fr">Borg modéré</rdfs:label>
        <rdfs:label xml:lang="en">Moderate borg</rdfs:label>
        <skos:definition xml:lang="en">A moderate level of perceived exertion characterized by increased breathing and heart rate, while conversation can still be maintained.</skos:definition>
        <skos:definition xml:lang="fr">Niveau d’effort perçu modéré caractérisé par une augmentation de la fréquence respiratoire et cardiaque, tout en permettant de maintenir une conversation.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Boxe">
        <rdfs:label xml:lang="fr">Boxe</rdfs:label>
        <rdfs:label xml:lang="en">Boxing</rdfs:label>
        <skos:definition xml:lang="en">Combat sport opposing two participants using punching techniques under codified rules.</skos:definition>
        <skos:definition xml:lang="fr">Sport de combat opposant deux adversaires utilisant des techniques de frappe avec les poings selon des règles codifiées.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#BronchopneumopathieChroniqueObstructive">
        <rdfs:label xml:lang="fr">Bronchopneumopathie chronique obstructive (BPCO)</rdfs:label>
        <rdfs:label xml:lang="en">Chronic obstructive pulmonary disease (COPD)</rdfs:label>
        <skos:definition xml:lang="en">A chronic lung disease characterized by persistent and progressive airflow limitation, associated with breathing difficulties, chronic cough, and reduced ventilatory capacity.</skos:definition>
        <skos:definition xml:lang="fr">Maladie pulmonaire chronique caractérisée par une obstruction progressive et persistante du flux aérien, associée à des difficultés respiratoires, une toux chronique et une limitation de la capacité ventilatoire.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/13645005"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Cancer">
        <rdfs:label xml:lang="en">Cancer</rdfs:label>
        <rdfs:label xml:lang="fr">Cancer</rdfs:label>
        <skos:definition xml:lang="en">Cancer is a disease characterized by the uncontrolled proliferation of abnormal cells resulting from genetic or epigenetic alterations, which may invade surrounding tissues and spread to other parts of the body through metastasis.</skos:definition>
        <skos:definition xml:lang="fr">Le cancer est une maladie caractérisée par une prolifération incontrôlée de cellules anormales résultant d’altérations génétiques ou épigénétiques, pouvant envahir les tissus environnants et se propager à d’autres parties de l’organisme par le biais de métastases.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/363346000"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#CardiopathiesInflammatoires">
        <rdfs:label xml:lang="fr">Cardiopathie inflammatoire</rdfs:label>
        <rdfs:label xml:lang="en">Inflammatory heart disease</rdfs:label>
        <skos:definition xml:lang="en">A cardiac condition characterized by inflammation of heart structures, potentially affecting the myocardium, pericardium, or endocardium and impairing cardiac function.</skos:definition>
        <skos:definition xml:lang="fr">Pathologie cardiaque caractérisée par une inflammation des structures du cœur, pouvant affecter le myocarde, le péricarde ou l’endocarde et altérer la fonction cardiaque.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#CardiopathiesStructurelle">
        <rdfs:label xml:lang="fr">Cardiopathie structurelle</rdfs:label>
        <rdfs:label xml:lang="en">Structural heart disease</rdfs:label>
        <skos:definition xml:lang="en">A cardiac condition involving an anatomical or functional abnormality of the heart structure, congenital or acquired, potentially affecting hemodynamic function.</skos:definition>
        <skos:definition xml:lang="fr">Pathologie cardiaque liée à une anomalie anatomique ou fonctionnelle de la structure du cœur, congénitale ou acquise, pouvant modifier la fonction hémodynamique.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/128599005"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Chaise">
        <rdfs:label xml:lang="fr">Chaise</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ChaiseContreMur">
        <rdfs:label xml:lang="fr">Chaise contre le mur</rdfs:label>
        <rdfs:label xml:lang="en">Wall squat hold</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ChargeLegere">
        <rdfs:label xml:lang="fr">Charge légère</rdfs:label>
        <rdfs:label xml:lang="en">Light load</rdfs:label>
        <skos:definition xml:lang="en">Use of low resistance to limit muscular and cardiovascular strain.</skos:definition>
        <skos:definition xml:lang="fr">Utilisation de résistances faibles afin de limiter la contrainte musculaire et cardiovasculaire.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ChoixActivite">
        <rdfs:label xml:lang="en">Activity choice</rdfs:label>
        <rdfs:label xml:lang="fr">Choix de l&apos;activité</rdfs:label>
        <skos:definition xml:lang="en">Allowing the patient to select the activity to increase autonomy and motivation.</skos:definition>
        <skos:definition xml:lang="fr">Possibilité laissée au patient de sélectionner l’activité afin d’augmenter l’autonomie et la motivation.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Climat">
        <rdfs:label xml:lang="fr">Climat</rdfs:label>
        <rdfs:label xml:lang="en">Climate</rdfs:label>
        <skos:definition xml:lang="fr">Ensemble des conditions atmosphériques moyennes caractérisant une région donnée et susceptibles d’influencer la pratique d’une activité physique.</skos:definition>
        <skos:definition xml:lang="en">Set of average atmospheric conditions characterizing a given region and potentially influencing physical activity practice.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ClimatEnsoleille">
        <rdfs:label xml:lang="fr">Climat ensoleillé</rdfs:label>
        <rdfs:label xml:lang="en">Sunny climate</rdfs:label>
        <skos:definition xml:lang="en">Climatic condition characterized by frequent and prolonged exposure to sunlight.</skos:definition>
        <skos:definition>Condition climatique caractérisée par une exposition fréquente et prolongée au rayonnement solaire.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ClimatFroid">
        <rdfs:label xml:lang="fr">Climat froid</rdfs:label>
        <rdfs:label xml:lang="en">Cold climate</rdfs:label>
        <skos:definition xml:lang="en">Condition climatique caractérisée par des températures basses susceptibles d’influencer la pratique d’activités extérieures.</skos:definition>
        <skos:definition xml:lang="fr">Condition climatique caractérisée par des températures basses susceptibles d’influencer la pratique d’activités extérieures.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ClimatPluvieux">
        <rdfs:label xml:lang="fr">Climat pluvieux</rdfs:label>
        <rdfs:label xml:lang="en">Rainy climate</rdfs:label>
        <skos:definition xml:lang="en">Climatic condition characterized by frequent precipitation that may limit or modify outdoor physical activity practice.</skos:definition>
        <skos:definition xml:lang="fr">Condition climatique caractérisée par des précipitations fréquentes pouvant limiter ou modifier la pratique d’activités extérieures.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ClimatVenteux">
        <rdfs:label xml:lang="fr">Climat venteux</rdfs:label>
        <rdfs:label xml:lang="en">Windy climate</rdfs:label>
        <skos:definition xml:lang="en">Climatic condition characterized by frequent or intense winds that may affect safety or comfort during outdoor physical activity.</skos:definition>
        <skos:definition xml:lang="fr">Condition climatique caractérisée par des vents fréquents ou intenses susceptibles d’affecter la sécurité ou le confort lors d’une activité physique extérieure.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#CoherenceCardiaque">
        <rdfs:label xml:lang="en">Cardiac coherence breathing</rdfs:label>
        <rdfs:label xml:lang="fr">Cohérence cardiaque</rdfs:label>
        <skos:definition xml:lang="en">Controlled breathing technique aimed at regulating heart rate variability.</skos:definition>
        <skos:definition xml:lang="fr">Technique de respiration contrôlée visant à réguler la variabilité de la fréquence cardiaque.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ContrainteProfessionnelle">
        <rdfs:label xml:lang="fr">Contraintes professionnelles</rdfs:label>
        <rdfs:label xml:lang="en">Work-related constraints</rdfs:label>
        <skos:definition xml:lang="fr">Ensemble des obligations professionnelles susceptibles de limiter le temps, l’énergie ou la disponibilité pour la pratique d’une activité physique.</skos:definition>
        <skos:definition xml:lang="en">Set of occupational obligations that may limit time, energy, or availability for physical activity practice.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ContreLeMur">
        <rdfs:label xml:lang="en">Against the wall</rdfs:label>
        <rdfs:label xml:lang="fr">Contre le mur</rdfs:label>
        <skos:definition xml:lang="fr">Exercice réalisé avec appui contre un mur pour améliorer l’équilibre ou réduire la charge.</skos:definition>
        <skos:definition xml:lang="en">Exercise performed with wall support to improve balance or reduce load.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#CoronaropathieAsymptomatique">
        <rdfs:label xml:lang="en">Asymptomatic coronary artery disease</rdfs:label>
        <rdfs:label xml:lang="fr">Coronaropathie asymptomatique</rdfs:label>
        <skos:definition xml:lang="en">Coronary artery disease present without apparent clinical symptoms, often detected during screening or cardiovascular investigations.</skos:definition>
        <skos:definition xml:lang="fr">Présence d’une maladie coronarienne objectivée sans symptômes cliniques apparents, pouvant être détectée lors d’examens de dépistage ou d’explorations cardiovasculaires.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/315348000"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#CoronaropathieChronique">
        <rdfs:label xml:lang="en">Chronic coronary syndrome</rdfs:label>
        <rdfs:label xml:lang="fr">Coronaropathie chronique</rdfs:label>
        <skos:definition xml:lang="en">A stable and progressive form of coronary artery disease characterized by persistent reduction of myocardial blood flow, potentially leading to exertional ischemic symptoms.</skos:definition>
        <skos:definition xml:lang="fr">Forme stable et évolutive de la maladie coronarienne caractérisée par une réduction durable du flux sanguin myocardique, pouvant entraîner des symptômes d’ischémie à l’effort.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#CoronaropathieFonctionnelle">
        <rdfs:label xml:lang="fr">Coronaropathie fonctionnelle</rdfs:label>
        <rdfs:label xml:lang="en">Functional coronary disorder</rdfs:label>
        <skos:definition xml:lang="en">A coronary disorder without major anatomical obstruction, related to functional abnormalities of coronary circulation that may cause myocardial ischemia.</skos:definition>
        <skos:definition xml:lang="fr">Trouble coronarien sans obstruction anatomique majeure, lié à des anomalies fonctionnelles de la circulation coronarienne, pouvant provoquer une ischémie myocardique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#CoursePied">
        <rdfs:label xml:lang="fr">Course à pied</rdfs:label>
        <rdfs:label xml:lang="en">Running</rdfs:label>
        <skos:definition xml:lang="fr">Activité physique locomotrice terrestre caractérisée par un déplacement bipède incluant une phase de suspension, impliquant principalement les membres inférieurs et le système cardiovasculaire.</skos:definition>
        <skos:definition xml:lang="en">Terrestrial locomotor physical activity characterized by bipedal movement including a suspension phase, primarily engaging the lower limbs and the cardiovascular system.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/418060005"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#CreneauxMatinSoir">
        <rdfs:label xml:lang="fr">Créneaux matin et soir</rdfs:label>
        <rdfs:label xml:lang="en">Morning and evening time slots</rdfs:label>
        <skos:definition xml:lang="fr">Planification de la pratique à des moments définis pour favoriser l’ancrage comportemental.</skos:definition>
        <skos:definition xml:lang="en">Scheduling practice at defined times to promote behavioral consistency.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Crunch">
        <rdfs:label xml:lang="en">Crunch</rdfs:label>
        <rdfs:label xml:lang="fr">Crunch</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Cycloergometre">
        <rdfs:label xml:lang="en">Cycle ergometer</rdfs:label>
        <rdfs:label xml:lang="fr">Cycloergomètre</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#DT1">
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/46635009"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#DT2">
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/44054006"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#DefebrillateurPortable">
        <rdfs:label xml:lang="fr">Défébrillateur portable</rdfs:label>
        <rdfs:label xml:lang="fr">Wearable defibrillator</rdfs:label>
        <skos:definition xml:lang="en">An external wearable medical device that continuously monitors cardiac rhythm and automatically delivers an electrical shock when a life-threatening ventricular arrhythmia is detected.</skos:definition>
        <skos:definition xml:lang="fr">Dispositif médical externe porté sur le corps permettant la surveillance continue du rythme cardiaque et la délivrance automatique d’un choc électrique en cas d’arythmie ventriculaire potentiellement mortelle.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/467017000"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#DeveloppeCouche">
        <rdfs:label xml:lang="en">Bench press</rdfs:label>
        <rdfs:label xml:lang="fr">Développé couché</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Diabete">
        <rdfs:label xml:lang="en">Diabete</rdfs:label>
        <rdfs:label xml:lang="fr">Diabète</rdfs:label>
        <skos:definition xml:lang="en">Diabetes is a chronic metabolic disease characterized by persistent hyperglycemia resulting from impaired insulin secretion, insulin resistance, or both, leading to disturbances in carbohydrate, lipid, and protein metabolism.</skos:definition>
        <skos:definition xml:lang="fr">Le diabète est une maladie métabolique chronique caractérisée par une hyperglycémie persistante résultant d’un défaut de sécrétion d’insuline, d’une résistance à l’insuline, ou des deux, entraînant des perturbations du métabolisme des glucides, des lipides et des protéines.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/73211009"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Diastasis">
        <rdfs:label xml:lang="fr">Diastasis</rdfs:label>
        <rdfs:label xml:lang="en">Rectus diastasis</rdfs:label>
        <skos:definition xml:lang="en">A separation of the left and right rectus abdominis muscles along the midline (linea alba) due to widening of connective tissue without a true fascial defect, which may result in abdominal bulging during effort.</skos:definition>
        <skos:definition xml:lang="fr">Séparation des muscles droits de l’abdomen au niveau de la ligne médiane (ligne blanche) résultant d’un élargissement du tissu conjonctif sans véritable défaut pariétal, pouvant entraîner une protrusion abdominale lors des efforts.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/62629000"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#DispositifMedical">
        <rdfs:label xml:lang="fr">Dipositif médical</rdfs:label>
        <rdfs:label xml:lang="en">Medical device</rdfs:label>
        <skos:broadMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/49062001"/>
        <skos:definition xml:lang="en">An instrument, device, or software intended for medical use in diagnosis, prevention, monitoring, or treatment of a health condition.</skos:definition>
        <skos:definition xml:lang="fr">Instrument, appareil ou logiciel utilisé à des fins médicales pour le diagnostic, la prévention, le suivi ou le traitement d’un problème de santé.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#EchauffementProlonge">
        <rdfs:label xml:lang="fr">Echauffement prolongé</rdfs:label>
        <rdfs:label xml:lang="en">Prolonged warm-up</rdfs:label>
        <skos:definition xml:lang="en">Extended preparatory phase to improve exercise tolerance and reduce cardiovascular risk.</skos:definition>
        <skos:definition xml:lang="fr">Phase préparatoire étendue visant à améliorer la tolérance à l’effort et réduire le risque cardiovasculaire.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Elastique">
        <rdfs:label xml:lang="en">Resistance band</rdfs:label>
        <rdfs:label xml:lang="fr">Élastique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ElevationFrontale">
        <rdfs:label xml:lang="en">Front raise</rdfs:label>
        <rdfs:label xml:lang="fr">Élévation frontale</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ElevationLaterale">
        <rdfs:label xml:lang="en">Lateral raise</rdfs:label>
        <rdfs:label xml:lang="fr">Élévation latérale</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Endocardite">
        <rdfs:label xml:lang="fr">Endocardite</rdfs:label>
        <rdfs:label xml:lang="en">Endocarditis</rdfs:label>
        <skos:definition xml:lang="fr">Inflammation de l’endocarde, la membrane interne du cœur, le plus souvent d’origine infectieuse, pouvant toucher les valves cardiaques et altérer leur fonctionnement.</skos:definition>
        <skos:definition xml:lang="en">Inflammation of the endocardium, the inner lining of the heart, most often of infectious origin, which may affect the heart valves and impair their function.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/56819008"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Equipement_de_sport">
        <rdfs:label xml:lang="en">Sports equipment</rdfs:label>
        <rdfs:label xml:lang="fr">Équipement de sport</rdfs:label>
        <skos:definition xml:lang="en">Equipment used for practicing physical or sporting activities.</skos:definition>
        <skos:definition xml:lang="fr">Matériel utilisé pour la pratique d’une activité physique ou sportive.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Etirement">
        <rdfs:label xml:lang="en">Stretching</rdfs:label>
        <rdfs:label xml:lang="fr">Étirement</rdfs:label>
        <skos:definition xml:lang="en">An exercise aimed at gradually lengthening muscles and related structures to improve or maintain flexibility and joint range of motion.</skos:definition>
        <skos:definition xml:lang="fr">Exercice visant à allonger progressivement les muscles et les structures associées afin d’améliorer ou de maintenir la souplesse et l’amplitude articulaire.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/122546009"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Eventration">
        <rdfs:label xml:lang="en">Eventration</rdfs:label>
        <rdfs:label xml:lang="fr">Éventration</rdfs:label>
        <skos:definition xml:lang="fr">Protrusion d’organes ou de tissus à travers une zone fragilisée de la paroi abdominale, généralement secondaire à une intervention chirurgicale ou à une faiblesse musculaire, sans véritable sac herniaire.</skos:definition>
        <skos:definition xml:lang="en">Protrusion of organs or tissues through a weakened area of the abdominal wall, usually secondary to surgery or muscular weakness, without a true hernial sac.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/37291000"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ExercicesIntegresAuQuotidien">
        <rdfs:label xml:lang="en">Daily-life integrated exercises</rdfs:label>
        <rdfs:label xml:lang="fr">Exercices intégrés au quotidien</rdfs:label>
        <skos:definition xml:lang="en">Integration of exercises into daily activities to increase overall activity volume.</skos:definition>
        <skos:definition xml:lang="fr">Intégration d’exercices dans les activités quotidiennes afin d’augmenter le volume global d’activité.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ExpositionProgressiveCharge">
        <rdfs:label xml:lang="fr">Exposition progressive à la charge</rdfs:label>
        <rdfs:label xml:lang="en">Gradual load progression</rdfs:label>
        <skos:definition>Augmentation progressive de l’intensité ou du volume afin d’optimiser l’adaptation physiologique.</skos:definition>
        <skos:definition xml:lang="en">Gradual increase in intensity or volume to optimize physiological adaptation.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ExtensionDeGenou">
        <rdfs:label xml:lang="fr">Extension de genou</rdfs:label>
        <rdfs:label xml:lang="en">Knee extension</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ExtensionDeHanche">
        <rdfs:label xml:lang="fr">Extension de hanche</rdfs:label>
        <rdfs:label xml:lang="en">Hip extension</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ExtensionDeMollet">
        <rdfs:label xml:lang="en">Ankle plantar flexion exercise</rdfs:label>
        <rdfs:label xml:lang="fr">Extension de mollet</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ExtensionTricep">
        <rdfs:label xml:lang="fr">Extension triceps</rdfs:label>
        <rdfs:label xml:lang="en">Triceps extension</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#FatiguePhysique">
        <rdfs:label xml:lang="fr">Fatigue physique</rdfs:label>
        <rdfs:label xml:lang="en">Physical fatigue</rdfs:label>
        <skos:definition xml:lang="en">Transient or persistent reduction in physical capacity resulting from exertion, pathology, or physiological imbalance.</skos:definition>
        <skos:definition xml:lang="fr">État de diminution transitoire ou persistante des capacités physiques résultant d’un effort, d’une pathologie ou d’un déséquilibre physiologique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#FatiguePsychologique">
        <rdfs:label xml:lang="fr">Fatigue psychologique</rdfs:label>
        <rdfs:label xml:lang="en">Mental fatigue</rdfs:label>
        <skos:definition xml:lang="en">State of reduced cognitive and emotional resources potentially affecting engagement in physical activity.</skos:definition>
        <skos:definition xml:lang="fr">État de diminution des ressources cognitives et émotionnelles susceptible d’affecter l’engagement dans une activité physique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Feminin">
        <rdfs:label xml:lang="en">Female</rdfs:label>
        <rdfs:label xml:lang="fr">Féminin</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Fentes">
        <rdfs:label xml:lang="fr">Fentes</rdfs:label>
        <rdfs:label xml:lang="en">Lunges</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#FlexionDeGenou">
        <rdfs:label xml:lang="fr">Flexion de genou</rdfs:label>
        <rdfs:label xml:lang="en">Knee flexion</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#FlexionDuCoude">
        <rdfs:label xml:lang="en">Elbow flexion</rdfs:label>
        <rdfs:label xml:lang="fr">Flexion du coude</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Football">
        <skos:definition xml:lang="en">Sport collectif opposant deux équipes dont l’objectif est de marquer des buts en propulsant un ballon principalement à l’aide des pieds.</skos:definition>
        <skos:definition xml:lang="fr">Sport collectif opposant deux équipes dont l’objectif est de marquer des buts en propulsant un ballon principalement à l’aide des pieds.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#FractionnementJournalier">
        <rdfs:label xml:lang="en">Daily session splitting</rdfs:label>
        <rdfs:label xml:lang="fr">Fractionnement journalier</rdfs:label>
        <skos:definition xml:lang="fr">Division de la séance en plusieurs périodes courtes réparties sur la journée.</skos:definition>
        <skos:definition xml:lang="en">Splitting a session into several shorter periods throughout the day.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Frein">
        <rdfs:label>Barrier</rdfs:label>
        <rdfs:label xml:lang="fr">Frein</rdfs:label>
        <skos:definition xml:lang="en">A limiting factor that reduces or prevents engagement in or maintenance of a behaviour or activity.</skos:definition>
        <skos:definition xml:lang="fr">Facteur limitant ou empêchant l’engagement ou le maintien d’un comportement ou d’une activité.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#FreinEnvironnemental">
        <rdfs:label xml:lang="en">Environmental barrier</rdfs:label>
        <rdfs:label xml:lang="fr">Frein environnemental</rdfs:label>
        <skos:definition xml:lang="en">A factor related to the physical or organizational environment that limits or prevents activity participation, such as access to facilities, weather conditions, or logistical constraints.</skos:definition>
        <skos:definition xml:lang="fr">Facteur lié à l’environnement physique ou organisationnel pouvant limiter ou empêcher la pratique d’une activité, comme l’accès aux infrastructures, le climat ou les contraintes logistiques.</skos:definition>
        <skos:definition xml:lang="fr">Manque de lieu accessible, d’équipements ou d’infrastructures favorables à la pratique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#FreinMotivationnel">
        <rdfs:label xml:lang="fr">Frein motivationnel</rdfs:label>
        <rdfs:label xml:lang="en">Motivational barrier</rdfs:label>
        <skos:definition xml:lang="en">A mental or emotional factor that limits activity engagement, such as anxiety, fear, lack of confidence, or negative beliefs.</skos:definition>
        <skos:definition xml:lang="fr">Facteur interne réduisant l’envie ou la volonté de s’engager ou de maintenir une activité, tel qu’un manque d’intérêt, d’objectifs ou de perception de bénéfices.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#FreinPhysique">
        <rdfs:label xml:lang="fr">Frein physique</rdfs:label>
        <rdfs:label xml:lang="en">Physical barrier</rdfs:label>
        <skos:definition xml:lang="en">A limitation related to health status, functional capacity, or physical condition that restricts activity performance.</skos:definition>
        <skos:definition xml:lang="fr">Limitation liée à l’état de santé, aux capacités fonctionnelles ou à la condition physique pouvant restreindre la réalisation d’une activité.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#FreinPsychologique">
        <rdfs:label xml:lang="fr">Frein psychologique</rdfs:label>
        <rdfs:label xml:lang="en">Psychological barrier</rdfs:label>
        <skos:definition xml:lang="en">A mental or emotional factor that limits activity engagement, such as anxiety, fear, lack of confidence, or negative beliefs.</skos:definition>
        <skos:definition xml:lang="fr">Facteur mental ou émotionnel pouvant limiter l’engagement dans une activité, comme l’anxiété, la peur, le manque de confiance ou des croyances négatives.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#FreinSituationnel">
        <rdfs:label xml:lang="fr">Frein situationnel</rdfs:label>
        <rdfs:label xml:lang="en">Situational barrier</rdfs:label>
        <skos:definition xml:lang="en">A barrier related to temporary or contextual circumstances, such as lack of time, family or work obligations, or life events.</skos:definition>
        <skos:definition xml:lang="fr">Obstacle lié à des circonstances temporaires ou contextuelles, telles que le manque de temps, des obligations familiales ou professionnelles ou des événements de vie.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#FreinSocial">
        <rdfs:label xml:lang="fr">Frein social</rdfs:label>
        <rdfs:label xml:lang="en">Social barrier</rdfs:label>
        <skos:definition xml:lang="en">A factor related to social interactions or relational context that limits activity participation, such as lack of support or social isolation.</skos:definition>
        <skos:definition xml:lang="fr">Facteur lié aux interactions sociales ou au contexte relationnel pouvant limiter la participation à une activité, comme le manque de soutien ou l’isolement social.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Gainage">
        <rdfs:label xml:lang="fr">Gainage</rdfs:label>
        <rdfs:label xml:lang="en">Plank exercie</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Genre">
        <rdfs:label xml:lang="en">Gender</rdfs:label>
        <rdfs:label xml:lang="fr">Genre</rdfs:label>
        <skos:definition xml:lang="en">A characteristic describing a person’s gender identity or social category related to sex, used for demographic description.</skos:definition>
        <skos:definition xml:lang="fr">Caractéristique décrivant l’identité ou la catégorie sociale liée au sexe d’une personne, utilisée pour la description démographique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Haltere">
        <rdfs:label xml:lang="en">Dumbbell</rdfs:label>
        <rdfs:label xml:lang="fr">Haltère</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Handball">
        <skos:definition xml:lang="fr">Sport collectif opposant deux équipes dont l’objectif est de marquer des buts en lançant un ballon à la main dans le but adverse.</skos:definition>
        <skos:definition xml:lang="en">Team sport opposing two teams aiming to score goals by throwing a ball by hand into the opponent’s goal.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#HernieInguinale">
        <rdfs:label xml:lang="fr">Hernie inguinale</rdfs:label>
        <rdfs:label xml:lang="en">Inguinal hernia</rdfs:label>
        <skos:definition xml:lang="fr">Protrusion d’un organe ou d’un tissu à travers une faiblesse de la paroi abdominale au niveau de la région inguinale, pouvant entraîner une gêne, une douleur ou un risque d’étranglement herniaire.</skos:definition>
        <skos:definition xml:lang="en">Protrusion of an organ or tissue through a weak area of the abdominal wall in the groin region, which may cause discomfort, pain, or risk of hernia strangulation.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/396232000"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#HorairesIrreguliers">
        <rdfs:label xml:lang="fr">Horaires irreguliers</rdfs:label>
        <rdfs:label xml:lang="en">Irregular working hours</rdfs:label>
        <skos:definition xml:lang="fr">Organisation temporelle du travail caractérisée par des horaires variables ou atypiques pouvant perturber la régularité de la pratique d’activité physique.</skos:definition>
        <skos:definition xml:lang="en">Work schedule characterized by variable or atypical hours potentially disrupting regular physical activity practice.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Hypertension_arterielle">
        <rdfs:label xml:lang="en">High blood presure</rdfs:label>
        <rdfs:label xml:lang="fr">Hypertensiopon arterielle</rdfs:label>
        <skos:definition xml:lang="en">High blood pressure is a chronic condition characterized by a persistent elevation of blood pressure in the systemic arteries, generally defined as a systolic blood pressure ≥ 140 mmHg and/or a diastolic blood pressure ≥ 90 mmHg at rest.</skos:definition>
        <skos:definition xml:lang="fr">L’hypertension artérielle est une maladie chronique caractérisée par une élévation persistante de la pression artérielle dans les artères systémiques, généralement définie par une pression artérielle systolique ≥ 140 mmHg et/ou une pression artérielle diastolique ≥ 90 mmHg au repos.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/38341003"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#InfarctusDuMyocarde">
        <rdfs:label xml:lang="fr">Infarctus du myocarde</rdfs:label>
        <rdfs:label xml:lang="en">Myocardial infarction</rdfs:label>
        <skos:definition xml:lang="en">An acute event characterized by necrosis of cardiac muscle caused by prolonged interruption of coronary blood supply.</skos:definition>
        <skos:definition xml:lang="fr">Événement aigu caractérisé par une nécrose du muscle cardiaque due à une interruption prolongée de l’apport sanguin coronaire.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/22298006"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#IntensiteBorg">
        <rdfs:label xml:lang="en">Borg perceived level</rdfs:label>
        <rdfs:label xml:lang="fr">Intensité Borg</rdfs:label>
        <skos:closeMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/263487004"/>
        <skos:definition xml:lang="en">Level of perceived exertion experienced during physical activity, commonly assessed using the Borg Rating of Perceived Exertion scale.</skos:definition>
        <skos:definition xml:lang="fr">Niveau d’effort perçu par une personne lors d’une activité physique, généralement évalué à l’aide de l’échelle de perception de l’effort de Borg.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#IntoleranceEffort">
        <rdfs:label xml:lang="en">Exercise intolerance</rdfs:label>
        <rdfs:label xml:lang="fr">Intolérence à l&apos;effort</rdfs:label>
        <skos:definition xml:lang="en">Inability or difficulty sustaining physical exertion due to physiological, cardiovascular, respiratory, or muscular limitations.</skos:definition>
        <skos:definition xml:lang="fr">Incapacité ou difficulté à maintenir un effort physique en raison de limitations physiologiques, cardiovasculaires, respiratoires ou musculaires.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#IschemieMyocardiqueStable">
        <rdfs:label xml:lang="fr">Ischémie myocardique stable</rdfs:label>
        <rdfs:label xml:lang="en">Stable myocardial ischemia</rdfs:label>
        <skos:definition xml:lang="en">A chronic and generally predictable reduction in blood supply to the myocardium, often triggered by exertion and reversible at rest, without acute instability.</skos:definition>
        <skos:definition xml:lang="fr">Diminution chronique et généralement prévisible de l’apport sanguin au myocarde, souvent déclenchée par l’effort et réversible au repos, sans caractère aigu instable.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/414795007"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ItineraireSecurise">
        <rdfs:label xml:lang="fr">Itinéraire sécurisé</rdfs:label>
        <rdfs:label xml:lang="en">Safe route</rdfs:label>
        <skos:definition xml:lang="fr">Choix d’un parcours limitant les risques environnementaux (circulation, relief).</skos:definition>
        <skos:definition xml:lang="en">Selection of a route minimizing environmental risks (traffic, terrain).</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Judo">
        <rdfs:label xml:lang="fr">Judo</rdfs:label>
        <skos:definition xml:lang="en">Combat sport based on throwing, immobilization, and control techniques without the use of strikes.</skos:definition>
        <skos:definition xml:lang="fr">Sport de combat fondé sur des techniques de projection, d’immobilisation et de contrôle de l’adversaire sans recours aux frappes.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Karate">
        <rdfs:label xml:lang="fr">Karate</rdfs:label>
        <skos:definition xml:lang="fr">Combat sport based on throwing, immobilization, and control techniques without the use of strikes.</skos:definition>
        <skos:definition xml:lang="en">Combat sport involving striking techniques using upper and lower limbs, practiced under formalized rules.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Ketelbell">
        <rdfs:label xml:lang="en">Kettlebell</rdfs:label>
        <rdfs:label xml:lang="fr">Kettlebell</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Kinesiophobie">
        <rdfs:label xml:lang="en">Kinesiophobia</rdfs:label>
        <rdfs:label xml:lang="fr">Kinésiophobie</rdfs:label>
        <skos:definition xml:lang="en">Excessive or irrational fear of movement or physical activity related to anticipated pain, injury, or disease exacerbation.</skos:definition>
        <skos:definition xml:lang="fr">Peur excessive ou irrationnelle du mouvement ou de l’activité physique liée à la crainte de douleur, de blessure ou d’aggravation d’une pathologie.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Leste">
        <rdfs:label xml:lang="fr">Leste</rdfs:label>
        <rdfs:label xml:lang="en">Weighted load</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Levier">
        <rdfs:label xml:lang="en">Facilitator</rdfs:label>
        <rdfs:label xml:lang="fr">Levier</rdfs:label>
        <skos:definition xml:lang="en">A facilitating factor that increases the likelihood of adopting or maintaining a behaviour or activity.</skos:definition>
        <skos:definition xml:lang="fr">Facteur facilitant ou augmentant la probabilité d’adoption ou de maintien d’un comportement ou d’une activité.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Lombalgie">
        <rdfs:label xml:lang="fr">Lombalgie</rdfs:label>
        <rdfs:label xml:lang="en">Low back pain</rdfs:label>
        <skos:definition xml:lang="fr">Douleur localisée dans la partie basse de la colonne vertébrale (région lombaire), pouvant être aiguë, subaiguë ou chronique selon sa durée d’évolution.</skos:definition>
        <skos:definition xml:lang="en">Pain located in the lower part of the spine (lumbar region), which may be acute, subacute, or chronic depending on duration.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#MachineGuidee">
        <rdfs:label xml:lang="en">Guided machine</rdfs:label>
        <rdfs:label xml:lang="fr">Machine guidée</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ManqueDeTempsLibre">
        <rdfs:label xml:lang="en">Lack of free time</rdfs:label>
        <rdfs:label xml:lang="fr">Manque de temps libre</rdfs:label>
        <skos:definition xml:lang="en">Perceived or actual insufficient time availability to incorporate physical activity into daily schedules.</skos:definition>
        <skos:definition xml:lang="fr">Perception ou réalité d’une disponibilité temporelle insuffisante pour intégrer une activité physique dans l’emploi du temps quotidien.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ManqueMotivationExtrinseque">
        <rdfs:label xml:lang="en">Lack of extrinsic motivation</rdfs:label>
        <rdfs:label xml:lang="fr">Manque de motivation extrinsèque</rdfs:label>
        <skos:definition xml:lang="fr">Diminution ou absence de motivation liée à des facteurs externes tels que la reconnaissance sociale, les récompenses ou les contraintes perçues.</skos:definition>
        <skos:definition xml:lang="en">Reduced or absent motivation driven by external factors such as social recognition, rewards, or perceived obligations.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ManqueMotivationIntrinseque">
        <rdfs:label xml:lang="en">Lack of intrinsic motivation</rdfs:label>
        <rdfs:label xml:lang="fr">Manqnue de motivation intrinsèque</rdfs:label>
        <skos:definition xml:lang="fr">Diminution ou absence de motivation liée à l’intérêt personnel, au plaisir ou à la satisfaction interne associés à la pratique d’une activité physique.</skos:definition>
        <skos:definition xml:lang="en">Reduced or absent motivation driven by personal interest, enjoyment, or internal satisfaction associated with physical activity practice.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Marathon">
        <rdfs:label xml:lang="fr">Marathon</rdfs:label>
        <rdfs:label xml:lang="en">Marathon running</rdfs:label>
        <skos:definition xml:lang="en">Endurance running event performed over a standardized distance of 42.195 kilometers, predominantly relying on aerobic metabolism.</skos:definition>
        <skos:definition xml:lang="fr">Épreuve de course à pied d’endurance sur une distance standardisée de 42,195 kilomètres, mobilisant principalement le métabolisme aérobie.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Marche">
        <rdfs:label xml:lang="fr">Marche</rdfs:label>
        <rdfs:label xml:lang="en">Walk</rdfs:label>
        <skos:definition xml:lang="fr">Activité physique locomotrice caractérisée par un déplacement bipède à allure modérée, sans phase de suspension complète du corps.</skos:definition>
        <skos:definition xml:lang="en">Locomotor physical activity characterized by bipedal movement at a moderate pace without a full suspension phase.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#MarcheAutourDuDomicile">
        <rdfs:label xml:lang="fr">Marche autour du domicile</rdfs:label>
        <rdfs:label xml:lang="en">Walking near homeE</rdfs:label>
        <skos:definition xml:lang="fr">Pratique de marche dans l’environnement immédiat du domicile pour faciliter la régularité.</skos:definition>
        <skos:definition xml:lang="en">Walking in the immediate residential environment to facilitate regular practice.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#MarcheNordique">
        <rdfs:label xml:lang="fr">Marche nordique</rdfs:label>
        <rdfs:label xml:lang="en">Nordic walking</rdfs:label>
        <skos:definition xml:lang="fr">Modalité de marche utilisant des bâtons spécifiques afin d’augmenter l’engagement musculaire des membres supérieurs et la dépense énergétique.</skos:definition>
        <skos:definition xml:lang="en">Walking modality using dedicated poles to increase upper-body muscular engagement and energy expenditure.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#MarcheSurCheminPlat">
        <rdfs:label xml:lang="en">Flat-path walking</rdfs:label>
        <rdfs:label xml:lang="fr">Marche sur chemin plat</rdfs:label>
        <skos:definition xml:lang="fr">Marche réalisée sur terrain peu incliné afin de limiter la contrainte cardiovasculaire.</skos:definition>
        <skos:definition xml:lang="en">Walking performed on low-gradient terrain to limit cardiovascular strain.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#MarcheSurTapis">
        <rdfs:label xml:lang="fr">Marche sur tapis</rdfs:label>
        <rdfs:label xml:lang="en">Treadmill walking</rdfs:label>
        <skos:definition xml:lang="fr">Marche réalisée sur tapis roulant permettant un contrôle précis de la vitesse et de l’inclinaison.</skos:definition>
        <skos:definition xml:lang="en">Walking performed on a treadmill allowing precise control of speed and incline.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Masculin">
        <rdfs:label xml:lang="en">Male</rdfs:label>
        <rdfs:label xml:lang="fr">Masculin</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Menisectomie">
        <rdfs:label xml:lang="en">Meniscectomy</rdfs:label>
        <rdfs:label xml:lang="fr">Méniscectomie</rdfs:label>
        <skos:definition xml:lang="en">A surgical procedure involving partial or total removal of a knee meniscus in order to treat a meniscal injury or relieve pain and mechanical symptoms.</skos:definition>
        <skos:definition xml:lang="fr">Acte chirurgical consistant à retirer partiellement ou totalement un ménisque du genou afin de traiter une lésion méniscale ou de soulager des symptômes douloureux et mécaniques.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#MicroSeance10Min">
        <rdfs:label xml:lang="en">10-minute micro-session</rdfs:label>
        <rdfs:label xml:lang="fr">Micro séance 10 min</rdfs:label>
        <skos:definition xml:lang="en">Short session of approximately 10 minutes promoting accessibility and schedule integration.</skos:definition>
        <skos:definition xml:lang="fr">Séance brève d’environ 10 minutes favorisant l’accessibilité et l’intégration dans l’emploi du temps.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#MonteeProgressiveIntensite">
        <rdfs:label xml:lang="en">Gradual intensity progression</rdfs:label>
        <rdfs:label xml:lang="fr">Montée progressive d’intensité</rdfs:label>
        <skos:definition xml:lang="fr">Augmentation progressive de l’intensité de l’effort afin de favoriser l’adaptation physiologique sécurisée.</skos:definition>
        <skos:definition xml:lang="en">Progressive increase in exercise intensity to promote safe physiological adaptation.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Moto">
        <rdfs:label xml:lang="fr">Moto</rdfs:label>
        <rdfs:label xml:lang="en">Motorcycle racing</rdfs:label>
        <skos:definition xml:lang="en">Motorsport involving competitive riding of motorcycles on a defined circuit or track.</skos:definition>
        <skos:definition xml:lang="fr">Sport motorisé impliquant la conduite compétitive de motocyclettes sur circuit ou parcours défini.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#MusculationLourde">
        <rdfs:label xml:lang="en">Heavy weight training</rdfs:label>
        <rdfs:label xml:lang="fr">Musculation lourde</rdfs:label>
        <skos:definition xml:lang="fr">Modalité d’activité physique consistant en la réalisation d’exercices de renforcement musculaire avec des charges élevées, généralement proches de la capacité maximale de force, impliquant une sollicitation neuromusculaire importante et des contraintes mécaniques élevées.</skos:definition>
        <skos:definition xml:lang="en">Physical activity modality involving the performance of strength exercises using high external loads, typically near maximal force capacity, resulting in significant neuromuscular demand and elevated mechanical stress.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Myocardite">
        <rdfs:label xml:lang="fr">Myocardite</rdfs:label>
        <rdfs:label xml:lang="en">Myocarditis</rdfs:label>
        <skos:definition xml:lang="fr">Inflammation du myocarde, le muscle cardiaque, pouvant entraîner une altération de la fonction contractile du cœur et provoquer des troubles du rythme ou une insuffisance cardiaque.</skos:definition>
        <skos:definition xml:lang="en">Inflammation of the myocardium, the heart muscle, potentially causing impaired cardiac contractile function, arrhythmias, or heart failure.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/50920009"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Nage">
        <rdfs:label xml:lang="fr">Nage</rdfs:label>
        <rdfs:label xml:lang="en">Swim</rdfs:label>
        <skos:definition xml:lang="fr">Activité physique locomotrice réalisée en milieu aquatique, caractérisée par des mouvements coordonnés des membres et du tronc permettant la propulsion et le déplacement dans l’eau.</skos:definition>
        <skos:definition xml:lang="en">Locomotor physical activity performed in an aquatic environment, characterized by coordinated movements of the limbs and trunk enabling propulsion and displacement in water.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Natation">
        <rdfs:label xml:lang="fr">Natation</rdfs:label>
        <rdfs:label xml:lang="en">Swimming</rdfs:label>
        <skos:definition xml:lang="fr">Activité physique réalisée en milieu aquatique impliquant des mouvements coordonnés des membres permettant la propulsion et le déplacement dans l’eau.</skos:definition>
        <skos:definition xml:lang="en">Physical activity performed in an aquatic environment involving coordinated limb movements enabling propulsion and displacement in water.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Obesite">
        <rdfs:label xml:lang="en">Obesity</rdfs:label>
        <rdfs:label xml:lang="fr">Obésité</rdfs:label>
        <skos:definition xml:lang="fr">L’obésité est une maladie chronique caractérisée par une accumulation excessive de tissu adipeux pouvant altérer la santé, généralement définie par un indice de masse corporelle (IMC) supérieur ou égal à 30 kg/m².</skos:definition>
        <skos:definition xml:lang="en">Obesity is a chronic disease characterized by excessive accumulation of adipose tissue that may impair health, generally defined as a body mass index (BMI) greater than or equal to 30 kg/m².</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/414916001"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Objectif">
        <rdfs:label xml:lang="en">Goal</rdfs:label>
        <rdfs:label xml:lang="fr">Objectif</rdfs:label>
        <skos:definition xml:lang="en">An intended outcome or target that an intervention or prescription aims to achieve.</skos:definition>
        <skos:definition xml:lang="fr">Résultat attendu ou cible définie qu’une intervention ou une prescription cherche à atteindre.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ObjectifSimple">
        <rdfs:label xml:lang="fr">Objectif simple</rdfs:label>
        <rdfs:label xml:lang="en">Simple goal</rdfs:label>
        <skos:definition xml:lang="en">Definition of a clear and achievable goal to promote progressive engagement.</skos:definition>
        <skos:definition xml:lang="fr">Définition d’un objectif clair et atteignable afin de favoriser l’engagement progressif.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Parachutisme">
        <rdfs:label xml:lang="fr">Parachutisme</rdfs:label>
        <rdfs:label xml:lang="en">Skydiving</rdfs:label>
        <skos:definition xml:lang="fr">Activité sportive consistant en un saut depuis un aéronef avec ouverture contrôlée d’un parachute pour assurer la descente.</skos:definition>
        <skos:definition xml:lang="en">Sport activity involving a jump from an aircraft followed by controlled parachute deployment for descent.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ParcourDeSante">
        <rdfs:label xml:lang="en">Outdoor fitness trail</rdfs:label>
        <rdfs:label xml:lang="fr">Parcours de santé</rdfs:label>
        <skos:definition xml:lang="fr">Itinéraire équipé d’installations permettant la réalisation d’exercices en extérieur.</skos:definition>
        <skos:definition xml:lang="en">Outdoor trail equipped with installations allowing exercise performance.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PasDeChargeLourdeHautDuCorps">
        <rdfs:label xml:lang="en">Avoid heavy upper-body loads</rdfs:label>
        <rdfs:label xml:lang="fr">Pas de charge lourde haut du corps</rdfs:label>
        <skos:definition xml:lang="en">Avoidance of heavy loads involving the upper limbs to limit blood pressure response.</skos:definition>
        <skos:definition xml:lang="fr">Évitement des charges importantes impliquant les membres supérieurs afin de limiter la réponse tensionnelle.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PasEffortIntense">
        <rdfs:label xml:lang="en">No intense effort</rdfs:label>
        <rdfs:label xml:lang="fr">Pas d&apos;effort intense</rdfs:label>
        <skos:definition xml:lang="fr">Limitation de l’exercice à des intensités modérées ou faibles afin d’éviter un stress cardiovasculaire excessif.</skos:definition>
        <skos:definition xml:lang="en">Restriction of exercise to low or moderate intensity to avoid excessive cardiovascular stress.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PasIsometrie">
        <rdfs:label xml:lang="en">No isometric exercise</rdfs:label>
        <rdfs:label xml:lang="fr">Pas d&apos;isométrie</rdfs:label>
        <skos:definition xml:lang="fr">Exclusion des contractions musculaires statiques prolongées susceptibles d’augmenter la pression artérielle.</skos:definition>
        <skos:definition xml:lang="en">Exclusion of sustained static muscle contractions that may increase blood pressure.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Pathologie">
        <rdfs:label xml:lang="en">Medical condition</rdfs:label>
        <rdfs:label xml:lang="fr">Pathologie</rdfs:label>
        <skos:broadMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/64572001"/>
        <skos:definition xml:lang="en">A medical condition or disease characterized by a deviation from normal health status.</skos:definition>
        <skos:definition xml:lang="fr">Condition médicale ou maladie caractérisée par une altération de l’état normal de santé.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PathologieCardiaque">
        <rdfs:label xml:lang="en">Heart disease</rdfs:label>
        <rdfs:label xml:lang="fr">Pathologie cardiaque</rdfs:label>
        <skos:broadMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/53741008"/>
        <skos:definition xml:lang="en">A medical condition affecting the structure or function of the heart, potentially impairing blood circulation and functional capacity.</skos:definition>
        <skos:definition xml:lang="fr">Condition médicale affectant la structure ou la fonction du cœur, pouvant altérer la circulation sanguine et la capacité fonctionnelle de l’individu.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PathologieCoronarienne">
        <rdfs:label xml:lang="en">Coronary artery disease</rdfs:label>
        <rdfs:label xml:lang="fr">Pathologie coronarienne</rdfs:label>
        <skos:definition xml:lang="en">A cardiac condition resulting from disease of the coronary arteries leading to reduced blood supply to the myocardium and potentially causing myocardial ischemia.</skos:definition>
        <skos:definition xml:lang="fr">Pathologie cardiaque résultant d’une atteinte des artères coronaires entraînant une diminution de l’apport sanguin au myocarde, pouvant conduire à une ischémie myocardique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PathologieDigestive">
        <rdfs:label xml:lang="en">Digestive disease</rdfs:label>
        <rdfs:label xml:lang="fr">Pathologie digestive</rdfs:label>
        <skos:definition xml:lang="en">A medical condition affecting the digestive system, including organs involved in digestion, nutrient absorption, and metabolism.</skos:definition>
        <skos:definition xml:lang="fr">Condition médicale affectant le système digestif, incluant les organes impliqués dans la digestion, l’absorption et le métabolisme des nutriments.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PathologieMusculosquelettique">
        <rdfs:label xml:lang="en">Musculoskeletal disorder</rdfs:label>
        <rdfs:label xml:lang="fr">Pathologie musculosquelettique</rdfs:label>
        <skos:definition xml:lang="en">A medical condition affecting muscles, bones, joints, or related tissues, potentially causing functional limitations and pain.</skos:definition>
        <skos:definition xml:lang="fr">Condition médicale touchant les muscles, les os, les articulations ou les tissus associés, pouvant entraîner des limitations fonctionnelles et des douleurs.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PathologieRespiratoire">
        <rdfs:label xml:lang="fr">Pathologie respiratoire</rdfs:label>
        <rdfs:label xml:lang="en">Respiratory disease</rdfs:label>
        <skos:definition xml:lang="en">A medical condition affecting the airways or lungs, potentially impairing ventilation and gas exchange.</skos:definition>
        <skos:definition xml:lang="fr">Condition médicale affectant les voies respiratoires ou les poumons, pouvant altérer la ventilation et les échanges gazeux.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Patient">
        <rdfs:label xml:lang="en">Patient</rdfs:label>
        <rdfs:label xml:lang="fr">Patient</rdfs:label>
        <skos:definition xml:lang="en">A person receiving or likely to receive healthcare, medical monitoring, or health interventions due to a health condition, disease, or preventive need.</skos:definition>
        <skos:definition xml:lang="fr">Personne recevant ou susceptible de recevoir des soins, un suivi médical ou une intervention de santé en raison d’un état de santé, d’une pathologie ou d’un besoin de prévention.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/116154003"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Pericardite">
        <rdfs:label xml:lang="en">Pericarditis</rdfs:label>
        <rdfs:label xml:lang="fr">Péricardite</rdfs:label>
        <skos:definition xml:lang="fr">Inflammation du péricarde, la membrane entourant le cœur, pouvant provoquer une douleur thoracique et parfois un épanchement péricardique.</skos:definition>
        <skos:definition xml:lang="en">Inflammation of the pericardium, the membrane surrounding the heart, which may cause chest pain and sometimes pericardial effusion.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/3238004"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Personne">
        <rdfs:label xml:lang="en">Individual</rdfs:label>
        <rdfs:label xml:lang="fr">Personne</rdfs:label>
        <skos:definition xml:lang="en">A human individual considered as an entity that can possess characteristics, health states, and interactions.</skos:definition>
        <skos:definition xml:lang="fr">Individu humain considéré comme entité principale pouvant posséder des caractéristiques, des états de santé et des interactions.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PlongeeSousMarine">
        <rdfs:label xml:lang="fr">Plongée sous marine</rdfs:label>
        <rdfs:label xml:lang="en">Scuba diving</rdfs:label>
        <skos:definition xml:lang="fr">Activité sportive ou récréative consistant à évoluer en immersion prolongée sous l’eau à l’aide d’un équipement respiratoire autonome.</skos:definition>
        <skos:definition xml:lang="en">Sport or recreational activity involving prolonged underwater immersion using autonomous breathing equipment.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PontFessier">
        <rdfs:label xml:lang="en">Glute bridge</rdfs:label>
        <rdfs:label xml:lang="fr">Pont fessier</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PontageAortoCoronarien">
        <rdfs:label xml:lang="en">Coronary artery bypass graft</rdfs:label>
        <rdfs:label xml:lang="fr">Pontage aorto-coronarien</rdfs:label>
        <skos:definition xml:lang="en">A surgical procedure involving the creation of a vascular bypass using a graft to circumvent a blocked coronary artery and restore blood flow to the myocardium.</skos:definition>
        <skos:definition xml:lang="fr">Acte chirurgical consistant à créer une dérivation du flux sanguin en utilisant un greffon vasculaire afin de contourner une artère coronaire obstruée et restaurer l’irrigation du myocarde.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/232717009"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Poulie">
        <rdfs:label xml:lang="en">Cable pulley</rdfs:label>
        <rdfs:label xml:lang="fr">Poulie</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#PratiqueEnGroupe">
        <rdfs:label xml:lang="en">Group-based practice</rdfs:label>
        <rdfs:label xml:lang="fr">Pratiquer en groupe</rdfs:label>
        <skos:definition xml:lang="fr">Modalité d’activité physique réalisée en présence d’autres participants afin de favoriser le soutien social, la motivation et l’engagement.</skos:definition>
        <skos:definition xml:lang="fr">Physical activity performed with other participants to enhance social support, motivation, and adherence.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Prescription">
        <rdfs:label xml:lang="en">Prescription</rdfs:label>
        <rdfs:label xml:lang="fr">Prescription</rdfs:label>
        <skos:closeMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/310882002"/>
        <skos:definition xml:lang="en">A formal recommendation issued by a healthcare professional specifying an intervention, treatment, or activity to be performed.</skos:definition>
        <skos:definition xml:lang="fr">Recommandation ou indication formelle émise par un professionnel de santé définissant une intervention, un traitement ou une activité à réaliser.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Prothese">
        <rdfs:label xml:lang="en">Prothesis</rdfs:label>
        <rdfs:label xml:lang="fr">Prothèse</rdfs:label>
        <skos:definition xml:lang="en">A medical device intended to replace wholly or partially a missing or impaired body part in order to restore anatomical or functional capability.</skos:definition>
        <skos:definition xml:lang="fr">Dispositif médical destiné à remplacer totalement ou partiellement une partie du corps absente ou altérée afin de restaurer une fonction anatomique ou fonctionnelle.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/53350007"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ProtheseDeGenou">
        <rdfs:label xml:lang="en">Knee prothesis</rdfs:label>
        <rdfs:label xml:lang="fr">Prothèse de genou</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ProtheseDeHanche">
        <rdfs:label xml:lang="en">Hip prothesis</rdfs:label>
        <rdfs:label xml:lang="fr">Prothèse de hanche</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Randonnee">
        <rdfs:label xml:lang="en">Hiking</rdfs:label>
        <rdfs:label xml:lang="fr">Randonnée</rdfs:label>
        <skos:definition xml:lang="fr">Marche prolongée réalisée en milieu naturel, souvent sur terrain irrégulier ou avec dénivelé.</skos:definition>
        <skos:definition xml:lang="en">Prolonged walking performed in natural environments, often on uneven terrain or with elevation changes.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ReductionDeCharge">
        <rdfs:label xml:lang="en">Load reduction</rdfs:label>
        <rdfs:label xml:lang="fr">Réduction de charge</rdfs:label>
        <skos:definition xml:lang="en">Decrease in resistance or weight used to adapt the exercise to patient capacity.</skos:definition>
        <skos:definition xml:lang="fr">Diminution de la résistance ou du poids utilisé afin d’adapter l’exercice aux capacités du patient.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ReduireAmplitude">
        <rdfs:label xml:lang="en">Reduce range of motion</rdfs:label>
        <rdfs:label xml:lang="fr">Reduire amplitude</rdfs:label>
        <skos:definition xml:lang="fr">Diminution de l’amplitude articulaire du mouvement afin de limiter la contrainte mécanique ou la douleur.</skos:definition>
        <skos:definition xml:lang="en">Reduction of joint range of motion to limit mechanical strain or pain.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ReleveDeJambes">
        <rdfs:label xml:lang="en">Leg raise</rdfs:label>
        <rdfs:label xml:lang="fr">Relevé de jambes</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#RenforcementMusculaire">
        <rdfs:label xml:lang="fr">Renforcement musculaire</rdfs:label>
        <rdfs:label xml:lang="en">Resistance training</rdfs:label>
        <skos:definition xml:lang="en">A physical activity involving external resistance or body weight to increase or maintain muscular strength, endurance, and function.</skos:definition>
        <skos:definition xml:lang="fr">Activité physique impliquant une résistance externe ou le poids du corps afin d’augmenter ou maintenir la force, l’endurance et la fonction musculaire.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#RenforcementMusculaireBasDuCorps">
        <rdfs:label xml:lang="en">Lower-body strengthening</rdfs:label>
        <rdfs:label xml:lang="fr">Renforcment musculaire bas du corps</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#RenforcementMusculaireHautDuCorps">
        <rdfs:label xml:lang="en">Hight body muscle strengthening</rdfs:label>
        <rdfs:label xml:lang="fr">Renforcement musculaire haut du corps</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#RenforcementMusculaireTronc">
        <rdfs:label xml:lang="fr">Renforcement musculaire du tronc</rdfs:label>
        <rdfs:label xml:lang="en">️ Core muscle strengthening</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Rugby">
        <skos:definition xml:lang="en">Contact team sport opposing two teams, aiming to score points by carrying or kicking an oval ball into the opponent’s scoring area.</skos:definition>
        <skos:definition xml:lang="fr">Sport collectif de contact opposant deux équipes, dont l’objectif est de marquer des points en portant ou en frappant un ballon ovale dans la zone adverse.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SansImpact">
        <rdfs:label xml:lang="en">Low-impact</rdfs:label>
        <rdfs:label xml:lang="fr">Sans impact</rdfs:label>
        <skos:definition xml:lang="fr">Exercice réalisé sans phase de saut ou d’impact au sol afin de limiter la contrainte articulaire et cardiovasculaire.</skos:definition>
        <skos:definition xml:lang="en">Exercise performed without jumping or ground impact to reduce joint and cardiovascular stress.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SansMouvementAsymetrique">
        <rdfs:label xml:lang="en">No asymmetrical movement</rdfs:label>
        <rdfs:label xml:lang="fr">Sans mouvement asymétrique</rdfs:label>
        <skos:definition xml:lang="fr">Exclusion de mouvements unilatéraux ou déséquilibrés afin de réduire le risque de surcharge segmentaire.</skos:definition>
        <skos:definition xml:lang="en">Exclusion of unilateral or unbalanced movements to reduce segmental overload risk.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SkiAlpin">
        <rdfs:label xml:lang="fr">Ski alpin</rdfs:label>
        <skos:definition xml:lang="en">Alpin skiing</skos:definition>
        <skos:definition xml:lang="en">Sport de glisse pratiqué sur neige consistant en une descente sur terrain incliné au moyen de skis.</skos:definition>
        <skos:definition xml:lang="fr">Sport de glisse pratiqué sur neige consistant en une descente sur terrain incliné au moyen de skis.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SkiDeFond">
        <rdfs:label xml:lang="en">Cross country skiing</rdfs:label>
        <rdfs:label xml:lang="fr">Ski de fond</rdfs:label>
        <skos:definition xml:lang="en">Endurance snow sport involving horizontal or undulating displacement using skis, requiring significant cardiovascular engagement.</skos:definition>
        <skos:definition xml:lang="fr">Sport d’endurance pratiqué sur neige impliquant un déplacement horizontal ou vallonné au moyen de skis, sollicitant fortement le système cardiovasculaire.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Snow">
        <rdfs:label xml:lang="fr">Snowboard</rdfs:label>
        <rdfs:label xml:lang="en">Snowboarding</rdfs:label>
        <skos:definition xml:lang="en">Endurance snow sport involving horizontal or undulating displacement using skis, requiring significant cardiovascular engagement.</skos:definition>
        <skos:definition xml:lang="fr">Endurance snow sport involving horizontal or undulating displacement using skis, requiring significant cardiovascular engagement.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Solitude">
        <rdfs:label xml:lang="en">Social isolation</rdfs:label>
        <rdfs:label xml:lang="fr">Solitude</rdfs:label>
        <skos:definition xml:lang="fr">Absence perçue ou réelle de soutien social ou de partenaire d’activité susceptible d’affecter l’engagement dans la pratique physique.</skos:definition>
        <skos:definition xml:lang="en">Perceived or actual absence of social support or activity partner potentially affecting engagement in physical activity.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SouleveDeTerre">
        <rdfs:label xml:lang="en">Deadlift</rdfs:label>
        <rdfs:label xml:lang="fr">Soulevé de terre</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SpasmeCoronarien">
        <rdfs:label xml:lang="en">Coronary vasospasm</rdfs:label>
        <rdfs:label xml:lang="fr">Spasme coronarien</rdfs:label>
        <skos:closeMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/71772004"/>
        <skos:definition xml:lang="en">A transient abnormal constriction of a coronary artery resulting in temporary reduction of blood flow to the myocardium, which may cause myocardial ischemia and chest pain.</skos:definition>
        <skos:definition xml:lang="fr">Contraction transitoire et excessive d’une artère coronaire entraînant une diminution temporaire du flux sanguin vers le myocarde, pouvant provoquer une ischémie myocardique et des douleurs thoraciques.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Sport">
        <rdfs:label xml:lang="en">Sport</rdfs:label>
        <rdfs:label xml:lang="fr">Sport</rdfs:label>
        <skos:definition xml:lang="en">A structured and often competitive physical activity governed by rules and practiced for performance, recreation, or health purposes.</skos:definition>
        <skos:definition xml:lang="fr">Activité physique codifiée, organisée et souvent compétitive, régie par des règles et pratiquée à des fins de performance, de loisirs ou de santé.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SportAquatique">
        <rdfs:label xml:lang="en">Aquatic sport</rdfs:label>
        <rdfs:label xml:lang="fr">Sport aquatique</rdfs:label>
        <skos:definition xml:lang="en">Category of physical activity practiced in an aquatic environment, involving movement, propulsion, or effort performed in water.</skos:definition>
        <skos:definition xml:lang="fr">Catégorie d’activité physique pratiquée en milieu aquatique, impliquant un déplacement, une propulsion ou un effort réalisé dans l’eau.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SportCollectif">
        <rdfs:label xml:lang="fr">Sport collectif</rdfs:label>
        <rdfs:label xml:lang="en">Team sport</rdfs:label>
        <skos:definition xml:lang="en">Category of physical activity involving coordinated participation of multiple players organized into teams pursuing a shared objective.</skos:definition>
        <skos:definition xml:lang="fr">Catégorie d’activité physique impliquant la participation coordonnée de plusieurs joueurs organisés en équipes poursuivant un objectif commun.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SportDeGlisse">
        <rdfs:label xml:lang="en">Sliding sport</rdfs:label>
        <rdfs:label xml:lang="fr">Sport de glisse</rdfs:label>
        <skos:definition xml:lang="en">Category of sport characterized by movement over a smooth surface (snow, ice, or water) using specific equipment enabling sliding motion.</skos:definition>
        <skos:definition xml:lang="fr">Catégorie de sport caractérisée par un déplacement sur une surface lisse (neige, glace ou eau) au moyen d’un équipement spécifique permettant la glisse.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SportDeRaquette">
        <rdfs:label xml:lang="en">Racket sport</rdfs:label>
        <rdfs:label xml:lang="fr">Sport de raquettes</rdfs:label>
        <skos:definition xml:lang="en">Category of sport involving the use of a racket to strike a shuttlecock or ball, typically in singles or doubles opposition.</skos:definition>
        <skos:definition xml:lang="fr">Catégorie de sport impliquant l’utilisation d’une raquette pour frapper un volant ou une balle, généralement dans un contexte d’opposition individuelle ou en double.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SportEndurance">
        <rdfs:label xml:lang="en">Endurance sport</rdfs:label>
        <rdfs:label xml:lang="fr">Sport d&apos;endurance</rdfs:label>
        <skos:definition xml:lang="en">Category of physical activity characterized by sustained effort predominantly relying on aerobic metabolism and involving prolonged cardiovascular and respiratory engagement.</skos:definition>
        <skos:definition xml:lang="fr">Catégorie d’activité physique caractérisée par un effort prolongé mobilisant principalement le métabolisme aérobie et sollicitant durablement le système cardiovasculaire et respiratoire.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SportExtreme">
        <rdfs:label xml:lang="en">Extreme sport</rdfs:label>
        <rdfs:label xml:lang="fr">Sport extrême</rdfs:label>
        <skos:definition xml:lang="en">Category of sport characterized by a high level of perceived or actual risk, involving demanding environmental conditions or significant physical constraints.</skos:definition>
        <skos:definition xml:lang="fr">Catégorie de sport caractérisée par un niveau élevé de risque perçu ou réel, impliquant des conditions environnementales exigeantes ou des contraintes physiques importantes.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SportIndividuel">
        <rdfs:label xml:lang="en">Individual Sport</rdfs:label>
        <rdfs:label xml:lang="fr">Sport individuel</rdfs:label>
        <skos:definition xml:lang="en">Catégorie de sport pratiqué de manière autonome, sans coopération structurée avec des coéquipiers durant la performance.</skos:definition>
        <skos:definition xml:lang="fr">Catégorie de sport pratiqué de manière autonome, sans coopération structurée avec des coéquipiers durant la performance.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SportMotorise">
        <rdfs:label xml:lang="en">Motor sport</rdfs:label>
        <rdfs:label xml:lang="fr">Sport motorisé</rdfs:label>
        <skos:definition xml:lang="en">Category of sport involving competitive or recreational driving of motorized vehicles within a regulated framework.</skos:definition>
        <skos:definition xml:lang="en">Catégorie de sport impliquant la conduite compétitive ou récréative de véhicules motorisés dans un cadre réglementé.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Squash">
        <skos:definition xml:lang="en">Racket sport played in an enclosed court involving striking a ball against a front wall under specific rules.</skos:definition>
        <skos:definition xml:lang="fr">Sport de raquette pratiqué en espace clos consistant à frapper une balle contre un mur frontal selon des règles spécifiques.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Squat">
        <rdfs:label xml:lang="en">Squat</rdfs:label>
        <rdfs:label xml:lang="fr">Squat</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Stent">
        <rdfs:label xml:lang="en">Stent</rdfs:label>
        <rdfs:label xml:lang="fr">Stent</rdfs:label>
        <skos:definition xml:lang="en">A tubular medical device implanted in a vessel or anatomical duct to maintain patency and improve blood or fluid flow.</skos:definition>
        <skos:definition xml:lang="fr">Dispositif médical tubulaire implanté dans un vaisseau ou un conduit anatomique afin de maintenir son ouverture et d’améliorer le flux sanguin ou liquidien.</skos:definition>
        <skos:exactMatch rdf:resource="http://purl.bioontology.org/ontology/SNOMEDCT/65818007"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#Stress">
        <rdfs:label xml:lang="fr">Stress</rdfs:label>
        <skos:definition xml:lang="en">Psychophysiological response to perceived constraints that may negatively influence motivation or availability for physical activity.</skos:definition>
        <skos:definition xml:lang="fr">Réponse psychophysiologique à des contraintes perçues pouvant influencer négativement la motivation ou la disponibilité à pratiquer une activité physique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SurLesGenoux">
        <rdfs:label xml:lang="en">Knee position</rdfs:label>
        <rdfs:label xml:lang="fr">Sur les genoux</rdfs:label>
        <skos:definition xml:lang="fr">Exercice réalisé en position à genoux afin de modifier la charge mécanique ou l’engagement musculaire.</skos:definition>
        <skos:definition xml:lang="en">Exercise performed in kneeling position to modify mechanical load or muscle engagement.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SurTerrainPlat">
        <rdfs:label xml:lang="en">Flat ground</rdfs:label>
        <rdfs:label xml:lang="fr">Sur terrain plat</rdfs:label>
        <skos:definition xml:lang="en">Activity performed on flat surface to reduce cardiovascular and muscular strain.</skos:definition>
        <skos:definition xml:lang="fr">Activité réalisée sur surface plane afin de limiter la contrainte cardiovasculaire et musculaire.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#SwissBall">
