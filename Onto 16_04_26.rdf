    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#VeloElliptique">
        <rdfs:label xml:lang="fr">Vélo elliptique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#VeloStationnaire">
        <rdfs:label xml:lang="fr">Vélo stationnaire</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#VetementAdapte">
        <rdfs:label>Appropriate clothing</rdfs:label>
        <rdfs:label xml:lang="fr">Vêtement adapté</rdfs:label>
        <skos:definition xml:lang="fr">Port de vêtements adaptés aux conditions climatiques et à l’intensité de l’effort afin d’optimiser le confort et la sécurité.</skos:definition>
        <skos:definition xml:lang="en">Use of clothing adapted to climate and exercise intensity to optimize comfort and safety.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#VetementChaud">
        <rdfs:label xml:lang="fr">Vêtement chaud</rdfs:label>
        <skos:definition xml:lang="fr">Selection of an area protected from direct sunlight to reduce thermal stress.</skos:definition>
        <skos:definition xml:lang="en">Use of thermally appropriate clothing enabling exercise in cold environments.</skos:definition>
        <skos:definition xml:lang="en">Warm clothing</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#VoitureDeCourse">
        <rdfs:label xml:lang="en">Car racing</rdfs:label>
        <rdfs:label xml:lang="fr">Voitures de course</rdfs:label>
        <skos:definition xml:lang="en">Motorsport involving competitive driving of automobiles on a regulated circuit or course.</skos:definition>
        <skos:definition xml:lang="fr">Sport motorisé impliquant la conduite compétitive de véhicules automobiles sur circuit ou parcours réglementé.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ZoneHabitation">
        <rdfs:label xml:lang="en">Residential area</rdfs:label>
        <rdfs:label xml:lang="fr">Zone d&apos;habitation</rdfs:label>
        <skos:definition xml:lang="en">Geographical area primarily designated for residential use, potentially influencing access to physical activity facilities.</skos:definition>
        <skos:definition xml:lang="en">Zone géographique caractérisée par une occupation principalement résidentielle pouvant influencer l’accès aux infrastructures d’activité physique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ZoneLittorale">
        <rdfs:label xml:lang="en">Coastal area</rdfs:label>
        <rdfs:label xml:lang="fr">Zone littorale</rdfs:label>
        <skos:definition xml:lang="en">Geographical area located near the coastline, characterized by maritime environmental and climatic influence.</skos:definition>
        <skos:definition xml:lang="fr">Zone géographique située à proximité du littoral, caractérisée par une influence maritime sur l’environnement et les conditions climatiques.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ZoneMontagne">
        <rdfs:label xml:lang="en">Mountainous area</rdfs:label>
        <rdfs:label xml:lang="fr">Zone montagneuse</rdfs:label>
        <skos:definition xml:lang="en">Geographical area characterized by elevated terrain and specific environmental conditions potentially influencing physical activity practice.</skos:definition>
        <skos:definition xml:lang="fr">Zone géographique caractérisée par un relief élevé et des conditions environnementales spécifiques pouvant influencer la pratique d’activité physique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ZoneOmbrage">
        <rdfs:label xml:lang="en">Shaded area</rdfs:label>
        <rdfs:label xml:lang="fr">Zone ombragée</rdfs:label>
        <skos:definition xml:lang="en">Choix d’un espace protégé de l’exposition solaire directe afin de limiter le stress thermique.</skos:definition>
        <skos:definition xml:lang="fr">Choix d’un espace protégé de l’exposition solaire directe afin de limiter le stress thermique.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ZoneRurale">
        <rdfs:label xml:lang="en">Rural area</rdfs:label>
        <rdfs:label xml:lang="fr">Zone rurale</rdfs:label>
        <skos:definition xml:lang="en">Geographical area with low population density, typically characterized by predominance of natural or agricultural spaces.</skos:definition>
        <skos:definition xml:lang="fr">Zone géographique à faible densité de population, généralement caractérisée par une prédominance d’espaces naturels ou agricoles.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/mmolina/ontologies/2025/11/untitled-ontology-50#ZoneUrbaine">
        <rdfs:label xml:lang="en">Urban area</rdfs:label>
        <rdfs:label xml:lang="fr">Zone urbaine</rdfs:label>
        <skos:definition xml:lang="en">Geographical area with high population density, characterized by significant urban development and infrastructure concentration.</skos:definition>
        <skos:definition xml:lang="fr">Zone géographique à forte densité de population, caractérisée par une urbanisation importante et une concentration d’infrastructures.</skos:definition>
    </rdf:Description>
</rdf:RDF>



